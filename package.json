{
  "name": "agent-pretty-print",
  "version": "2.0.0",
  "description": "Parse and format JSONL log files with TUI and file output",
  "type": "module",
  "main": "dist/parse-log.js",
  "bin": {
    "agent-pretty-print": "./dist/parse-log.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Chizbro/agent-pretty-print.git"
  },
  "keywords": [
    "jsonl",
    "log",
    "parser",
    "cursor",
    "agent",
    "tui",
    "markdown"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "prepare": "node -e \"require('fs').existsSync('dist/parse-log.js') || require('child_process').execSync('npm run build', { stdio: 'inherit' })\"",
    "start": "node dist/parse-log.js",
    "parse": "tsx parse-log.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^4.4.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
