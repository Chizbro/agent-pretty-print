t                .merge(crate::routes::tasks::team_tasks_router())\n48\t                .merge(crate::routes::jobs::team_jobs_router()),\n49\t        )\n50\t        .nest(\"/tasks\", crate::routes::tasks::router())\n51\t        .nest(\"/jobs\", crate::routes::jobs::router())\n52\t        .nest(\"/credentials\", crate::routes::credentials::router())\n53\t        .merge(\n54\t            crate::routes::logs::router()\n55\t                .layer(middleware::from_fn_with_state(s.clone(), log_query_limit)),\n56\t        )\n57\t        .nest(\"/admin\", crate::routes::admin::router())\n58\t        .merge(crate::routes::events::router())\n59\t        .layer(middleware::from_fn_with_state(s.clone(), general_limit))\n60\t        .layer(middleware::from_fn_with_state(\n61\t            s.clone(),\n62\t            client_id_middleware,\n63\t        ));\n64\t\n65\t    Router::new()\n66\t        .route(\"/health\", get(health::health))\n67\t        .route(\n68\t            \"/auth/cli/:device_code\",\n69\t            get(crate::routes::auth::cli_login_page),\n70\t        )\n71\t        .route(\n72\t            \"/credentials/cli/:device_code\",\n73\t            get(crate::routes::credentials::sink_cli_page),\n74\t        )\n75\t        .nest(\"/api/v1\", api_v1)\n76\t        .nest(\"/internal\", crate::routes::internal::router())\n77\t        .layer(DefaultBodyLimit::max(1_048_576))\n78\t        .layer(\n79\t            TraceLayer::new_for_http().make_span_with(|req: &axum::http::Request<_>| {\n80\t                let rid = req\n81\t                    .extensions()\n82\t                    .get::<crate::state::RequestIds>()\n83\t                    .map(|r| r.request_id.as_str())\n84\t                    .unwrap_or(\"—\");\n85\t                tracing::info_span!(\n86\t                    \"http_request\",\n87\t                    method = %req.method(),\n88\t                    uri = %req.uri().path(),\n89\t                    request_id = %rid,\n90\t                    client_id = tracing::field::Empty,\n91\t                    entity_id = tracing::field::Empty,\n92\t                )\n93\t            }),\n94\t        )\n95\t        .layer(middleware::from_fn(request_id_middleware))\n96\t        .layer(cors_layer(&config))\n97\t        .with_state(state)\n98\t}\n99\t"}]},"parent_tool_use_id":"toolu_01GNGo3hHjPuggAghcHEPyyi","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"3cd1bf1d-5bc7-4dbb-84b5-c09f0e5dc196","timestamp":"2026-03-31T13:05:24.104Z"}
