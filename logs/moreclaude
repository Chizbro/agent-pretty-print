INBOX_NAME is required when MOCK_AGENT_CHILD_TASK_BODY is set\"\n50\t                        .to_string(),\n51\t            });\n52\t        }\n53\t\n54\t        Ok(Self {\n55\t            mode,\n56\t            result_summary: std::env::var(\"MOCK_AGENT_RESULT_SUMMARY\")\n57\t                .ok()\n58\t                .or_else(|| Some(\"Task completed by mock agent\".to_string())),\n59\t            child_task_body,\n60\t            child_inbox_name,\n61\t            fail_reason: std::env::var(\"MOCK_AGENT_FAIL_REASON\")\n62\t                .ok()\n63\t                .or_else(|| Some(\"Mock agent failure\".to_string())),\n64\t            hang_seconds: parse_u64_env(\"MOCK_AGENT_HANG_SECONDS\")?,\n65\t            write_file: std::env::var(\"MOCK_AGENT_WRITE_FILE\").ok(),\n66\t            write_content: std::env::var(\"MOCK_AGENT_WRITE_CONTENT\").ok(),\n67\t            delay_before_complete_ms: parse_u64_env(\"MOCK_AGENT_DELAY_MS\")?,\n68\t        })\n69\t    }\n70\t}\n71\t\n72\tfn parse_u64_env(name: &str) -> Result<Option<u64>, MockAgentError> {\n73\t    match std::env::var(name) {\n74\t        Ok(value) => value\n75\t            .parse::<u64>()\n76\t            .map(Some)\n77\t            .map_err(|e| MockAgentError::ConfigError {\n78\t                message: format!(\"invalid {name}: {e}\"),\n79\t            }),\n80\t        Err(_) => Ok(None),\n81\t    }\n82\t}\n83\t"}]},"parent_tool_use_id":"toolu_01Pu83J9SEJAt2TonKkonsLK","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"606acd5a-5b80-476a-ab19-3ce7d14d0862","timestamp":"2026-03-31T13:05:21.200Z"}
