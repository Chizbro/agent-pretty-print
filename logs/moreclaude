ks as task_db;\nuse crate::db::teams;\nuse crate::events::bus::PlatformEvent;\nuse crate::inbox_change::{classify_inbox_update, InboxMutationKind};\nuse crate::middleware::auth::AuthContext;\nuse crate::routes::agents::may_view_agent;\nuse crate::scheduler::{\n    AgentSnapshotConfig, McpServerConfig, SinkConfig as SchedulerSinkConfig, SinkCredentials,\n    StartInstanceRequest, TaskSummary,\n};\nuse crate::state::{AppState, ClientId};\nuse crate::task_response::task_row_to_response;\n\n#[derive(Serialize)]\nstruct InboxListEnvelope {\n    data: Vec<InboxResponse>,\n}\n\n#[derive(Debug, Deserialize)]\nstruct InboxTaskListQuery {\n    pub status: Option<TaskStatus>,\n    #[serde(flatten)]\n    pub page: PaginationParams,\n}\n\n#[derive(Serialize)]\nstruct SystemPromptPreviewBody {\n    system_prompt: String,\n}\n\nasync fn inbox_with_snapshot_response(\n    pool: &sqlx::PgPool,\n    row: inboxes::InboxWithSnapshot,\n) -> Result<InboxResponse, AppError> {\n    let queued = inboxes::count_queued_tasks(pool, row.id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    Ok(InboxResponse {\n        id: row.id,\n        name: row.name.clone(),\n        agent_snapshot_id: row.agent_snapshot_id,\n        agent_snapshot: Some(InboxListSnapshotSummary {\n            id: row.agent_snapshot_id,\n            name: row.snapshot_name.clone(),\n            llm_host: row.snapshot_llm_host,\n            orphaned: row.snapshot_orphaned,\n            source_agent_id: row.snapshot_source_agent_id,\n        }),\n        retry_count: row.retry_count,\n        queued_task_count: Some(queued),\n        created_at: Some(row.created_at),\n    })\n}\n\nasync fn list_inboxes_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path(team_id): Path<Uuid>,\n) -> Result<Json<InboxListEnvelope>, AppError> {\n    require_viewer(&state.db, team_id, &auth).await?;\n    let rows = inboxes::list_inboxes(&state.db, team_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    let mut data = Vec::with_capacity(rows.len());\n    for r in rows {\n        data.push(inbox_with_snapshot_response(&state.db, r).await?);\n    }\n    Ok(Json(InboxListEnvelope { data }))\n}\n\nasync fn create_inbox_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path(team_id): Path<Uuid>,\n    Json(req): Json<CreateInboxRequest>,\n) -> Result<(StatusCode, Json<InboxResponse>), AppError> {\n    require_owner(&state.db, team_id, &auth).await?;\n    validate_name(&req.name).map_err(|e| AppError::ValidationFailed { errors: vec![e] })?;\n    if req.retry_count < 0 {\n        return Err(AppError::ValidationFailed {\n            errors: vec![common::validation::ValidationError::new(\n                \"retry_count\",\n                \"must not be negative\",\n            )],\n        });\n    }\n    let agent = agents::get_agent(&state.db, req.agent_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"agent\",\n            id: req.agent_id.to_string(),\n        })?;\n    if !may_view_agent(&agent.agent, &auth) {\n        return Err(AppError::NotFound {\n            resource: \"agent\",\n            id: req.agent_id.to_string(),\n        });\n    }\n    let row = inboxes::create_inbox(&state.db, team_id, &req.name, req.agent_id, req.retry_count)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    let joined = inboxes::fetch_inbox_joined(&state.db, team_id, row.id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::Internal {\n            message: \"inbox missing after create\".to_string(),\n        })?;\n    let body = inbox_with_snapshot_response(&state.db, joined).await?;\n    Ok((StatusCode::CREATED, Json(body)))\n}\n\nasync fn patch_inbox_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n    Json(req): Json<UpdateInboxRequest>,\n) -> Result<Json<InboxResponse>, AppError> {\n    require_owner(&state.db, team_id, &auth).await?;\n    if let Some(ref n) = req.name {\n        validate_name(n).map_err(|e| AppError::ValidationFailed { errors: vec![e] })?;\n    }\n    if let Some(rc) = req.retry_count {\n        if rc < 0 {\n            return Err(AppError::ValidationFailed {\n                errors: vec![common::validation::ValidationError::new(\n                    \"retry_count\",\n                    \"must not be negative\",\n                )],\n            });\n        }\n    }\n    let inbox = inboxes::get_inbox(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n    let snap = inboxes::get_snapshot_for_inbox(&state.db, &inbox)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::Internal {\n            message: \"snapshot missing\".to_string(),\n        })?;\n\n    let kind = classify_inbox_update(&req, snap.source_agent_id);\n    if kind == InboxMutationKind::Reductive {\n        let running = crate::db::teams::has_running_jobs(&state.db, team_id)\n            .await\n            .map_err(|e| AppError::Internal {\n                message: e.to_string(),\n            })?;\n        if running {\n            return Err(AppError::Conflict {\n                message: \"reductive inbox change blocked while jobs are running\".to_string(),\n            });\n        }\n    }\n\n    let rebind = match req.agent_id {\n        None => None,\n        Some(aid) if Some(aid) == snap.source_agent_id && !snap.orphaned => None,\n        Some(aid) => Some(aid),\n    };\n\n    if let Some(aid) = rebind {\n        let agent = agents::get_agent(&state.db, aid)\n            .await\n            .map_err(|e| AppError::Internal {\n                message: e.to_string(),\n            })?\n            .ok_or_else(|| AppError::NotFound {\n                resource: \"agent\",\n                id: aid.to_string(),\n            })?;\n        if !may_view_agent(&agent.agent, &auth) {\n            return Err(AppError::NotFound {\n                resource: \"agent\",\n                id: aid.to_string(),\n            });\n        }\n    }\n\n    let updated = inboxes::apply_inbox_update(&state.db, team_id, inbox_id, &req, rebind)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n    let joined = inboxes::fetch_inbox_joined(&state.db, team_id, updated.id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n    Ok(Json(inbox_with_snapshot_response(&state.db, joined).await?))\n}\n\nasync fn delete_inbox_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n) -> Result<StatusCode, AppError> {\n    require_owner(&state.db, team_id, &auth).await?;\n    if crate::db::teams::has_running_jobs(&state.db, team_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n    {\n        return Err(AppError::Conflict {\n            message: \"cannot delete inbox while jobs are running\".to_string(),\n        });\n    }\n    let ok = inboxes::delete_inbox(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    if !ok {\n        return Err(AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        });\n    }\n    Ok(StatusCode::NO_CONTENT)\n}\n\nasync fn pull_inbox_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n) -> Result<Json<InboxResponse>, AppError> {\n    require_owner(&state.db, team_id, &auth).await?;\n    let inbox = inboxes::get_inbox(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n    let snap = inboxes::get_snapshot_for_inbox(&state.db, &inbox)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::Internal {\n            message: \"snapshot missing\".to_string(),\n        })?;\n    if snap.orphaned || snap.source_agent_id.is_none() {\n        return Err(AppError::Conflict {\n            message: \"cannot pull: snapshot is orphaned\".to_string(),\n        });\n    }\n    let joined = match inboxes::pull_agent_update(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })? {\n        Some(j) => j,\n        None => {\n            return Err(AppError::NotFound {\n                resource: \"inbox\",\n                id: inbox_id.to_string(),\n            });\n        }\n    };\n    Ok(Json(inbox_with_snapshot_response(&state.db, joined).await?))\n}\n\nasync fn create_root_task_handler(\n    auth: AuthContext,\n    Extension(client): Extension<ClientId>,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n    Json(req): Json<CreateTaskRequest>,\n) -> Result<(StatusCode, Json<TaskResponse>), AppError> {\n    require_collaborator(&state.db, team_id, &auth).await?;\n    let enabled: bool = sqlx::query_scalar(r#\"SELECT enabled FROM teams WHERE id = $1\"#)\n        .bind(team_id)\n        .fetch_optional(&state.db)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"team\",\n            id: team_id.to_string(),\n        })?;\n    if !enabled {\n        return Err(AppError::Conflict {\n            message: \"team is disabled\".to_string(),\n        });\n    }\n    validate_task_body(&req.body).map_err(|e| AppError::ValidationFailed { errors: vec![e] })?;\n    validate_sink_config(&req.sink.repo_url, &req.sink.branch)\n        .map_err(|e| AppError::ValidationFailed { errors: vec![e] })?;\n    let inbox = inboxes::get_inbox(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n    let team_name: String = sqlx::query_scalar(r#\"SELECT name FROM teams WHERE id = $1\"#)\n        .bind(team_id)\n        .fetch_one(&state.db)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n\n    let row = task_db::create_root_task(\n        &state.db,\n        team_id,\n        inbox.id,\n        &req,\n        auth.entity_type,\n        auth.entity_id,\n        &client.0,\n    )\n    .await\n    .map_err(|e| AppError::Internal {\n        message: e.to_string(),\n    })?;\n\n    let snapshot = inboxes::get_snapshot_for_inbox(&state.db, &inbox)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::Internal {\n            message: \"snapshot missing\".to_string(),\n        })?;\n    let sink_provider = row.sink_provider.ok_or_else(|| AppError::Internal {\n        message: \"root task sink provider missing\".to_string(),\n    })?;\n    let sink_repo_url = row\n        .sink_repo_url\n        .clone()\n        .ok_or_else(|| AppError::Internal {\n            message: \"root task sink repo missing\".to_string(),\n        })?;\n    let sink_branch = row.sink_branch.clone().ok_or_else(|| AppError::Internal {\n        message: \"root task sink branch missing\".to_string(),\n    })?;\n    let sink_push_mode = row.sink_push_mode.ok_or_else(|| AppError::Internal {\n        message: \"root task sink push mode missing\".to_string(),\n    })?;\n    let team_max: Option<i32> =\n        sqlx::query_scalar(r#\"SELECT max_concurrent_instances FROM teams WHERE id = $1\"#)\n            .bind(team_id)\n            .fetch_optional(&state.db)\n            .await\n            .map_err(|e| AppError::Internal {\n                message: e.to_string(),\n            })?\n            .flatten();\n\n    state\n        .scheduler\n        .start_instance(StartInstanceRequest {\n            instance_id: Uuid::new_v4(),\n            team_id,\n            team_max_instances: team_max.map(|v| v.max(0) as u32),\n            task_id: row.id,\n            root_task_id: row.root_task_id,\n            job_dir: None,\n            sink_config: SchedulerSinkConfig {\n                provider: sink_provider,\n                repo_url: sink_repo_url,\n                branch: sink_branch,\n                push_mode: sink_push_mode,\n                credentials: SinkCredentials {\n                    access_token: String::new(),\n                    refresh_token: String::new(),\n                    provider_username: None,\n                },\n            },\n            agent_snapshot: AgentSnapshotConfig {\n                llm_host: snapshot.llm_host,\n                agent_prompt: snapshot.agent_prompt,\n            },\n            system_prompt: common::system_prompt::render_system_prompt_preview(\n                &team_name,\n                team_id,\n                &[],\n                inbox.retry_count,\n            ),\n            task_body: row.body.clone(),\n            parent_chain: Vec::<TaskSummary>::new(),\n            mcp_server_config: McpServerConfig {\n                api_url: state.config.base_url.clone(),\n                instance_token: String::new(),\n                token_secret: String::new(),\n            },\n            heartbeat_timeout_seconds: state.config.heartbeat_interval_secs * 3,\n            instance_timeout_seconds: 3600,\n            llm_api_key: String::new(),\n        })\n        .await\n        .map_err(|_| AppError::Internal {\n            message: \"scheduler failed to start instance\".to_string(),\n        })?;\n\n    let _ = team_name;\n    state.event_bus.publish(PlatformEvent::TaskCreated {\n        team_id,\n        root_task_id: row.root_task_id,\n        task_id: row.id,\n        parent_task_id: row.parent_task_id,\n        inbox_id: row.inbox_id,\n        inbox_name: inbox.name.clone(),\n        body: row.body.clone(),\n    });\n\n    let tr = task_row_to_response(&row);\n    Ok((StatusCode::CREATED, Json(tr)))\n}\n\nasync fn list_inbox_tasks_handler(\n    auth: AuthContext,\n    Extension(_client): Extension<ClientId>,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n    Query(q): Query<InboxTaskListQuery>,\n) -> Result<Json<PaginatedResponse<TaskResponse>>, AppError> {\n    require_viewer(&state.db, team_id, &auth).await?;\n    let inbox = inboxes::get_inbox(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n\n    let limit = q.page.limit() as usize;\n    let after = match &q.page.cursor {\n        None => None,\n        Some(c) => Some(decode_cursor(c)?),\n    };\n    let mut rows = task_db::list_tasks_by_inbox(\n        &state.db,\n        team_id,\n        inbox.id,\n        q.status,\n        after,\n        q.page.limit(),\n    )\n    .await\n    .map_err(|e| AppError::Internal {\n        message: e.to_string(),\n    })?;\n    let next = task_db::next_tasks_cursor(&rows, limit);\n    if rows.len() > limit {\n        rows.pop();\n    }\n    let data: Vec<_> = rows.iter().map(task_row_to_response).collect();\n    Ok(Json(PaginatedResponse {\n        data,\n        next_cursor: next,\n    }))\n}\n\nasync fn system_prompt_preview_handler(\n    auth: AuthContext,\n    State(state): State<AppState>,\n    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n) -> Result<Json<SystemPromptPreviewBody>, AppError> {\n    require_viewer(&state.db, team_id, &auth).await?;\n    let detail = teams::get_team(&state.db, team_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"team\",\n            id: team_id.to_string(),\n        })?;\n\n    let joined = inboxes::fetch_inbox_joined(&state.db, team_id, inbox_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"inbox\",\n            id: inbox_id.to_string(),\n        })?;\n\n    let inbox_rows = inboxes::list_inboxes(&state.db, team_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    let lines: Vec<SystemPromptInboxInfo> = inbox_rows\n        .into_iter()\n        .map(|r| SystemPromptInboxInfo {\n            id: r.id,\n            name: r.name,\n            agent_name: r.snapshot_name,\n            llm_host: r.snapshot_llm_host,\n        })\n        .collect();\n\n    let system_prompt = common::system_prompt::render_system_prompt_preview(\n        &detail.team.name,\n        team_id,\n        &lines,\n        joined.retry_count,\n    );\n\n    Ok(Json(SystemPromptPreviewBody { system_prompt }))\n}\n\npub fn router() -> Router<AppState> {\n    Router::new()\n        .route(\n            \"/:team_id/inboxes\",\n            get(list_inboxes_handler).post(create_inbox_handler),\n        )\n        .route(\n            \"/:team_id/inboxes/:inbox_id\",\n            patch(patch_inbox_handler).delete(axum::routing::delete(delete_inbox_handler)),\n        )\n        .route(\"/:team_id/inboxes/:inbox_id/pull\", post(pull_inbox_handler))\n        .route(\n            \"/:team_id/inboxes/:inbox_id/tasks\",\n            get(list_inbox_tasks_handler).post(create_root_task_handler),\n        )\n        .route(\n            \"/:team_id/inboxes/:inbox_id/system-prompt-preview\",\n            get(system_prompt_preview_handler),\n        )\n}\n","numLines":585,"startLine":1,"totalLines":585}}}
