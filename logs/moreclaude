{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JHAuiZhDTafPPK2CRAVFoF","type":"tool_result","content":"1\t//! JWT signing and verification (RS256) with optional previous public key.\n2\t\n3\tuse crate::enums::EntityType;\n4\tuse chrono::Utc;\n5\tuse jsonwebtoken::{decode, encode, Algorithm, DecodingKey, EncodingKey, Header, Validation};\n6\tuse serde::{Deserialize, Serialize};\n7\tuse thiserror::Error;\n8\tuse uuid::Uuid;\n9\t\n10\t/// RSA keys for signing (current private) and verifying (current + optional previous public).\n11\tpub struct JwtKeys {\n12\t    current_private: EncodingKey,\n13\t    current_public: DecodingKey,\n14\t    previous_public: Option<DecodingKey>,\n15\t}\n16\t\n17\timpl JwtKeys {\n18\t    /// PEM from `AGENT_FARM_JWT_PRIVATE_KEY`, `AGENT_FARM_JWT_PUBLIC_KEY`,\n19\t    /// optional `AGENT_FARM_JWT_PUBLIC_KEY_PREVIOUS`.\n20\t    pub fn from_env() -> Result<Self, crate::config::ConfigError> {\n21\t        let priv_pem = required_pem(\"AGENT_FARM_JWT_PRIVATE_KEY\")?;\n22\t        let pub_pem = required_pem(\"AGENT_FARM_JWT_PUBLIC_KEY\")?;\n23\t        let prev = optional_pem(\"AGENT_FARM_JWT_PUBLIC_KEY_PREVIOUS\")?;\n24\t\n25\t        let current_private =\n26\t            EncodingKey::from_rsa_pem(priv_pem.as_bytes()).map_err(jwt_config_err)?;\n27\t        let current_public =\n28\t            DecodingKey::from_rsa_pem(pub_pem.as_bytes()).map_err(jwt_config_err)?;\n29\t        let previous_public = match prev {\n30\t            Some(p) => Some(DecodingKey::from_rsa_pem(p.as_bytes()).map_err(jwt_config_err)?),\n31\t            None => None,\n32\t        };\n33\t        Ok(Self {\n34\t            current_private,\n35\t            current_public,\n36\t            previous_public,\n37\t        })\n38\t    }\n39\t\n40\t    pub(crate) fn current_private(&self) -> &EncodingKey {\n41\t        &self.current_private\n42\t    }\n43\t\n44\t    pub(crate) fn current_public(&self) -> &DecodingKey {\n45\t        &self.current_public\n46\t    }\n47\t\n48\t    pub(crate) fn previous_public(&self) -> Option<&DecodingKey> {\n49\t        self.previous_public.as_ref()\n50\t    }\n51\t}\n52\t\n53\tfn required_pem(var: &'static str) -> Result<String, crate::config::ConfigError> {\n54\t    let raw =\n55\t        std::env::var(var).map_err(|_| crate::config::ConfigError::MissingVar(var.to_string()))?;\n56\t    if raw.trim().is_empty() {\n57\t        return Err(crate::config::ConfigError::MissingVar(var.to_string()));\n58\t    }\n59\t    Ok(raw)\n60\t}\n61\t\n62\tfn optional_pem(var: &'static str) -> Result<Option<String>, crate::config::ConfigError> {\n63\t    let Ok(raw) = std::env::var(var) else {\n64\t        return Ok(None);\n65\t    };\n66\t    if raw.trim().is_empty() {\n67\t        Ok(None)\n68\t    } else {\n69\t        Ok(Some(raw))\n70\t    }\n71\t}\n72\t\n73\tfn jwt_config_err(e: jsonwebtoken::errors::Error) -> crate::config::ConfigError {\n74\t    crate::config::ConfigError::InvalidValue {\n75\t        var: \"JWT keys\".to_string(),\n76\t        reason: e.to_string(),\n77\t    }\n78\t}\n79\t\n80\tfn validation() -> Validation {\n81\t    let mut v = Validation::new(Algorithm::RS256);\n82\t    v.validate_exp = true;\n83\t    v\n84\t}\n85\t\n86\t#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n87\tpub struct AccessTokenClaims {\n88\t    pub entity_type: EntityType,\n89\t    pub entity_id: Uuid,\n90\t    pub iat: i64,\n91\t    pub exp: i64,\n92\t}\n93\t\n94\t#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\n95\tpub struct InstanceTokenClaims {\n96\t    pub instance_id: Uuid,\n97\t    pub task_id: Uuid,\n98\t    pub root_task_id: Uuid,\n99\t    pub iat: i64,\n100\t    pub exp: i64,\n101\t}\n102\t\n103\t#[derive(Debug, Error, PartialEq, Eq)]\n104\tpub enum JwtError {\n105\t    #[error(\"JWT signing failed\")]\n106\t    SigningFailed,\n107\t    #[error(\"JWT verification failed\")]\n108\t    VerificationFailed,\n109\t    #[error(\"JWT expired\")]\n110\t    Expired,\n111\t    #[error(\"invalid JWT claims\")]\n112\t    InvalidClaims,\n113\t}\n114\t\n115\tpub fn sign_access_token(claims: &AccessTokenClaims, keys: &JwtKeys) -> Result<String, JwtError> {\n116\t    encode(\n117\t        &Header::new(Algorithm::RS256),\n118\t        claims,\n119\t        keys.current_private(),\n120\t    )\n121\t    .map_err(|_| JwtError::SigningFailed)\n122\t}\n123\t\n124\tpub fn verify_access_token(token: &str, keys: &JwtKeys) -> Result<AccessTokenClaims, JwtError> {\n125\t    verify_with_fallback(token, keys.current_public(), keys.previous_public())\n126\t}\n127\t\n128\tpub fn sign_instance_token(\n129\t    claims: &InstanceTokenClaims,\n130\t    keys: &JwtKeys,\n131\t) -> Result<String, JwtError> {\n132\t    encode(\n133\t        &Header::new(Algorithm::RS256),\n134\t        claims,\n135\t        keys.current_private(),\n136\t    )\n137\t    .map_err(|_| JwtError::SigningFailed)\n138\t}\n139\t\n140\tpub fn verify_instance_token(token: &str, keys: &JwtKeys) -> Result<InstanceTokenClaims, JwtError> {\n141\t    verify_with_fallback(token, keys.current_public(), keys.previous_public())\n142\t}\n143\t\n144\tfn verify_with_fallback<T: serde::de::DeserializeOwned>(\n145\t    token: &str,\n146\t    current: &DecodingKey,\n147\t    previous: Option<&DecodingKey>,\n148\t) -> Result<T, JwtError> {\n149\t    let v = validation();\n150\t    match decode::<T>(token, current, &v) {\n151\t        Ok(data) => Ok(data.claims),\n152\t        Err(e) => {\n153\t            use jsonwebtoken::errors::ErrorKind;\n154\t            let kind = e.kind();\n155\t            if matches!(kind, ErrorKind::ExpiredSignature) {\n156\t                return Err(JwtError::Expired);\n157\t            }\n158\t            if let Some(prev) = previous {\n159\t                match decode::<T>(token, prev, &v) {\n160\t                    Ok(data) => Ok(data.claims),\n161\t                    Err(e2) => {\n162\t                        if matches!(e2.kind(), ErrorKind::ExpiredSignature) {\n163\t                            Err(JwtError::Expired)\n164\t                        } else {\n165\t                            Err(JwtError::VerificationFailed)\n166\t                        }\n167\t                    }\n168\t                }\n169\t            } else {\n170\t                Err(JwtError::VerificationFailed)\n171\t            }\n172\t        }\n173\t    }\n174\t}\n175\t\n176\t/// Builds claims with `iat = now`, `exp = now + 15 minutes`, then signs.\n177\tpub fn issue_access_token(\n178\t    entity_type: EntityType,\n179\t    entity_id: Uuid,\n180\t    keys: &JwtKeys,\n181\t) -> Result<String, JwtError> {\n182\t    let now = Utc::now().timestamp();\n183\t    let claims = AccessTokenClaims {\n184\t        entity_type,\n185\t        entity_id,\n186\t        iat: now,\n187\t        exp: now + 15 * 60,\n188\t    };\n189\t    sign_access_token(&claims, keys)\n190\t}\n191\t\n192\t/// Instance JWT with the given wall-clock lifetime in seconds.\n193\tpub fn issue_instance_token(\n194\t    instance_id: Uuid,\n195\t    task_id: Uuid,\n196\t    root_task_id: Uuid,\n197\t    lifetime_secs: i64,\n198\t    keys: &JwtKeys,\n199\t) -> Result<String, JwtError> {\n200\t    let now = Utc::now().timestamp();\n201\t    let claims = InstanceTokenClaims {\n202\t        instance_id,\n203\t        task_id,\n204\t        root_task_id,\n205\t        iat: now,\n206\t        exp: now + lifetime_secs,\n207\t    };\n208\t    sign_instance_token(&claims, keys)\n209\t}\n210\t\n211\t#[cfg(test)]\n212\tmod tests {\n213\t    use super::*;\n214\t    use rsa::pkcs8::{EncodePrivateKey, EncodePublicKey, LineEnding};\n215\t    use rsa::{RsaPrivateKey, RsaPublicKey};\n216\t\n217\t    fn rsa_pair() -> (String, String) {\n218\t        let mut rng = rand::thread_rng();\n219\t        let private_key = RsaPrivateKey::new(&mut rng, 2048).expect(\"keygen\");\n220\t        let public_key = RsaPublicKey::from(&private_key);\n221\t        let priv_pem = private_key\n222\t            .to_pkcs8_pem(Line