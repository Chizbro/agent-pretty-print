id,\n55\t        q.category,\n56\t        q.since,\n57\t        q.until,\n58\t        after,\n59\t        q.page.limit(),\n60\t    )\n61\t    .await\n62\t    .map_err(|e| AppError::Internal {\n63\t        message: e.to_string(),\n64\t    })?;\n65\t    let next = if rows.len() > limit {\n66\t        rows.get(limit - 1)\n67\t            .map(|r| encode_cursor(r.timestamp, r.id))\n68\t    } else {\n69\t        None\n70\t    };\n71\t    if rows.len() > limit {\n72\t        rows.pop();\n73\t    }\n74\t    let data = rows\n75\t        .into_iter()\n76\t        .map(|r| LogEntryResponse {\n77\t            id: r.id,\n78\t            task_id: r.task_id,\n79\t            category: r.category,\n80\t            source: r.source,\n81\t            timestamp: r.timestamp,\n82\t            entry: r.entry,\n83\t        })\n84\t        .collect();\n85\t    Ok(Json(PaginatedResponse {\n86\t        data,\n87\t        next_cursor: next,\n88\t    }))\n89\t}\n90\t\n91\tasync fn job_logs_handler(\n92\t    auth: AuthContext,\n93\t    State(state): State<AppState>,\n94\t    Path(root_task_id): Path<Uuid>,\n95\t    Query(q): Query<LogQuery>,\n96\t) -> Result<Json<PaginatedResponse<LogEntryResponse>>, AppError> {\n97\t    let job = jobs::get_job(&state.db, root_task_id)\n98\t        .await\n99\t        .map_err(|e| AppError::Internal {\n100\t            message: e.to_string(),\n101\t        })?\n102\t        .ok_or_else(|| AppError::NotFound {\n103\t            resource: \"job\",\n104\t            id: root_task_id.to_string(),\n105\t        })?;\n106\t    require_viewer(&state.db, job.job.team_id, &auth).await?;\n107\t    let limit = q.page.limit() as usize;\n108\t    let after = q\n109\t        .page\n110\t        .cursor\n111\t        .as_ref()\n112\t        .map(|c| decode_cursor(c))\n113\t        .transpose()?;\n114\t    let mut rows = logs::query_logs_by_job(\n115\t        &state.db,\n116\t        root_task_id,\n117\t        q.category,\n118\t        q.since,\n119\t        q.until,\n120\t