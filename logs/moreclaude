{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RvBQgKZ3tMyzCB4VNpccsk","type":"tool_result","content":"1\t//! Opaque tokens and SHA-256 hashing for refresh / SP tokens.\n2\t\n3\tuse base64::engine::general_purpose::URL_SAFE_NO_PAD;\n4\tuse base64::Engine;\n5\tuse rand::RngCore;\n6\tuse sha2::{Digest, Sha256};\n7\t\n8\t/// 32 random bytes, base64url without padding (refresh tokens, OAuth state, device codes, etc.).\n9\tpub fn generate_opaque_token() -> String {\n10\t    let mut buf = [0u8; 32];\n11\t    rand::thread_rng().fill_bytes(&mut buf);\n12\t    URL_SAFE_NO_PAD.encode(buf)\n13\t}\n14\t\n15\t/// SHA-256 of the token string, lowercase hex.\n16\tpub fn hash_token(token: &str) -> String {\n17\t    let digest = Sha256::digest(token.as_bytes());\n18\t    hex_lower(&digest)\n19\t}\n20\t\n21\t/// 32 random bytes, base64url-encoded (Host Wrapper / MCP shared secret).\n22\tpub fn generate_shared_secret() -> String {\n23\t    generate_opaque_token()\n24\t}\n25\t\n26\tfn hex_lower(bytes: &[u8]) -> String {\n27\t    const HEX: &[u8; 16] = b\"0123456789abcdef\";\n28\t    let mut s = String::with_capacity(bytes.len() * 2);\n29\t    for b in bytes {\n30\t        s.push(HEX[(b >> 4) as usize] as char);\n31\t        s.push(HEX[(b & 0xf) as usize] as char);\n32\t    }\n33\t    s\n34\t}\n35\t\n36\t#[cfg(test)]\n37\tmod tests {\n38\t    use super::*;\n39\t\n40\t    #[test]\n41\t    fn opaque_token_nonempty_base64url() {\n42\t        let t = generate_opaque_token();\n43\t        assert!(!t.is_empty());\n44\t        assert!(!t.contains('+'));\n45\t        assert!(!t.contains('/'));\n46\t        assert!(!t.contains('='));\n47\t    }\n48\t\n49\t    #[test]\n50\t    fn opaque_tokens_differ() {\n51\t        assert_ne!(generate_opaque_token(), generate_opaque_token());\n52\t    }\n53\t\n54\t    #[test]\n55\t    fn hash_token_deterministic() {\n56\t        let a = hash_token(\"same\");\n57\t        let b = hash_token(\"same\");\n58\t        assert_eq!(a, b);\n59\t    }\n60\t\n61\t    #[test]\n62\t    fn hash_token_distinct_inputs() {\n63\t        assert_ne!(hash_token(\"one\"), hash_token(\"two\"));\n64\t    }\n65\t}\n66\t"}]},"parent_tool_use_id":"toolu_01KT8bJnvxAUTFsh7jnMAXxC","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"b5398572-6945-4e4e-bf41-596ed2ed41a8","timestamp":"2026-03-31T13:05:23.641Z"}
