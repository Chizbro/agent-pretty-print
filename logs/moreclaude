{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vbBYCRDtosVWrqKA1b3KC","type":"tool_result","content":"1\t//! Environment-driven application configuration (see `docs/07-INFRASTRUCTURE.md`).\n2\t\n3\tuse crate::crypto::encryption::EncryptionKeys;\n4\tuse crate::crypto::jwt::JwtKeys;\n5\tuse std::time::Duration;\n6\tuse thiserror::Error;\n7\t\n8\tconst DEFAULT_PORT: u16 = 8080;\n9\tconst DEFAULT_MAX_INSTANCES: u32 = 20;\n10\tconst DEFAULT_JOB_DIR_ROOT: &str = \"/data/jobs\";\n11\tconst DEFAULT_JOB_CLEANUP_GRACE_SECS: u64 = 3600;\n12\tconst DEFAULT_LOG_RETENTION_DAYS: u32 = 30;\n13\tconst DEFAULT_HEARTBEAT_INTERVAL_SECS: u32 = 30;\n14\tconst DEFAULT_GRACEFUL_SHUTDOWN_SECS: u32 = 30;\n15\tconst DEFAULT_LOG_LEVEL: &str = \"info\";\n16\t\n17\t/// Parsed platform configuration from environment variables.\n18\tpub struct AppConfig {\n19\t    pub database_url: String,\n20\t    pub base_url: String,\n21\t    pub encryption_keys: EncryptionKeys,\n22\t    pub jwt_keys: JwtKeys,\n23\t    pub port: u16,\n24\t    pub cors_origins: Vec<String>,\n25\t    pub max_concurrent_instances: u32,\n26\t    pub job_dir_root: String,\n27\t    pub job_cleanup_grace_period_secs: u64,\n28\t    pub log_retention_days: u32,\n29\t    pub heartbeat_interval_secs: u32,\n30\t    pub graceful_shutdown_timeout_secs: u32,\n31\t    pub log_level: String,\n32\t    pub github_client_id: Option<String>,\n33\t    pub github_client_secret: Option<String>,\n34\t    pub gitlab_client_id: Option<String>,\n35\t    pub gitlab_client_secret: Option<String>,\n36\t    /// When set, GitHub/GitLab OAuth token + userinfo HTTP calls target this origin (wiremock in tests).\n37\t    pub oauth_test_origin: Option<String>,\n38\t    /// GitHub REST API origin (override in tests, e.g. wiremock, for credential repo listing).\n39\t    pub github_api_base_url: String,\n40\t    /// GitLab REST API origin.\n41\t    pub gitlab_api_base_url: String,\n42\t    /// Anthropic API origin (override in tests).\n43\t    pub anthropic_api_base_url: String,\n44\t    /// OpenAI API origin (override in tests).\n45\t    pub openai_api_base_url: String,\n46\t    pub host_wrapper_bin: String,\n47\t    pub mcp_server_bin: String,\n48\t    pub claude_code_bin: Option<String>,\n49\t    pub cursor_cli_bin: Option<String>,\n50\t}\n51\t\n52\t#[derive(Debug, Error, PartialEq, Eq)]\n53\tpub enum ConfigError {\n54\t    #[error(\"missing or empty required environment variable: {0}\")]\n55\t    MissingVar(String),\n56\t    #[error(\"invalid value for {var}: {reason}\")]\n57\t    InvalidValue { var: String, reason: String },\n58\t    #[error(\"configure at least one OAuth provider with both client ID and secret (GitHub and/or GitLab)\")]\n59\t    NoOAuthProvider,\n60\t    #[error(\"configure at least one LLM host binary path (AGENT_FARM_CLAUDE_CODE_BIN and/or AGENT_FARM_CURSOR_CLI_BIN)\")]\n61\t    NoLlmHostBinary,\n62\t}\n63\t\n64\timpl AppConfig {\n65\t    /// Loads configuration from the process environment.\n66\t    pub fn from_env() -> Result<Self, ConfigError> {\n67\t        let database_url = req(\"DATABASE_URL\")?;\n68\t        let base_url = req(\"AGENT_FARM_BASE_URL\")?;\n69\t        let encryption_keys = EncryptionKeys::from_env()?;\n70\t        let jwt_keys = JwtKeys::from_env()?;\n71\t\n72\t        let host_wrapper_bin = req(\"AGENT_FARM_HOST_WRAPPER_BIN\")?;\n73\t        let mcp_server_bin = req(\"AGENT_FARM_MCP_SERVER_BIN\")?;\n74\t\n75\t        let github_client_id = opt(\"GITHUB_CLIENT_ID\");\n76\t        let github_client_secret = opt(\"GITHUB_CLIENT_SECRET\");\n77\t        let gitlab_client_id = opt(\"GITLAB_CLIENT_ID\");\n78\t        let gitlab_client_secret = opt(\"GITLAB_CLIENT_SECRET\");\n79\t\n80\t        let github_ok = github_client_id.is_some() && github_client_secret.is_some();\n81\t        let gitlab_ok = gitlab_client_id.is_some() && gitlab_client_secret.is_some();\n82\t        if !github_ok && !gitlab_ok {\n83\t            return Err(ConfigError::NoOAuthProvider);\