{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LyT9bBnRYhbh9x5gyaBqk6","type":"tool_result","content":"1\tuse std::collections::HashSet;\n2\tuse std::convert::Infallible;\n3\tuse std::time::Duration;\n4\t\n5\tuse axum::extract::{Path, Query, State};\n6\tuse axum::http::HeaderMap;\n7\tuse axum::response::sse::{Event as SseEvent, KeepAlive, Sse};\n8\tuse axum::routing::get;\n9\tuse axum::Router;\n10\tuse common::AppError;\n11\tuse futures::Stream;\n12\tuse serde::Deserialize;\n13\tuse uuid::Uuid;\n14\t\n15\tuse crate::auth::access::require_viewer;\n16\tuse crate::events::bus::{PlatformEvent, PlatformEventEnvelope};\n17\tuse crate::middleware::auth::AuthContext;\n18\tuse crate::state::AppState;\n19\t\n20\tfn to_sse(env: &PlatformEventEnvelope) -> SseEvent {\n21\t    let event_name = match &env.event {\n22\t        PlatformEvent::TaskStatusChanged { .. } => \"task_status_changed\",\n23\t        PlatformEvent::TaskCreated { .. } => \"task_created\",\n24\t        PlatformEvent::TaskRouted { .. } => \"task_routed\",\n25\t        PlatformEvent::InstanceStarted { .. } => \"instance_started\",\n26\t        PlatformEvent::InstanceExited { .. } => \"instance_exited\",\n27\t        PlatformEvent::Heartbeat { .. } => \"heartbeat\",\n28\t        PlatformEvent::DlqAddition { .. } => \"dlq_addition\",\n29\t        PlatformEvent::JobCompleted { .. } => \"job_completed\",\n30\t        PlatformEvent::LogEntry { .. } => \"log_entry\",\n31\t    };\n32\t    SseEvent::default()\n33\t        .id(env.id.to_string())\n34\t        .event(event_name)\n35\t        .data(serde_json::to_string(&env.event).unwrap_or_else(|_| \"{}\".to_string()))\n36\t}\n37\t\n38\tfn parse_last_event_id(headers: &HeaderMap) -> u64 {\n39\t    headers\n40\t        .get(\"Last-Event-ID\")\n41\t        .and_then(|v| v.to_str().ok())\n42\t        .and_then(|s| s.parse::<u64>().ok())\n43\t        .unwrap_or(0)\n44\t}\n45\t\n46\tasync fn job_events_handler(\n47\t    auth: AuthContext,\n48\t    headers: HeaderMap,\n49\t    State(state): State<AppState>,\n50\t    Path(root_task_id): Path<Uuid>,\n51\t) -> Result<Sse<impl Stream<Item = Result<SseEvent, Infallible>>>, AppError> {\n52\t    let job = crate::db::jobs::get_job(&state.db, root_task_id)\n53\t        .await\n54\t        .map_err(|e| AppError::Internal {\n55\t            message: e.to_string(),\n56\t        })?\n57\t        .ok_or_else(|| AppError::NotFound {\n58\t            resource: \"job\",\n59\t            id: root_task_id.to_string(),\n60\t        })?;\n61\t    require_viewer(&state.db, job.job.team_id, &auth).await?;\n62\t    let mut rx = state.event_bus.subscribe();\n63\t    let replay = state.event_bus.replay_since(parse_last_event_id(&headers));\n64\t    let stream = async_stream::stream! {\n65\t        for env in replay.into_iter().filter(|e| e.event.root_task_id() == Some(root_task_id)) {\n66\t            yield Ok(to_sse(&env));\n67\t        }\n68\t        let mut ticker = tokio::time::interval(Duration::from_secs(30));\n69\t        loop {\n70\t            tokio::select! {\n71\t                _ = ticker.tick() => yield Ok(SseEvent::default().comment(\"keepalive\")),\n72\t                recv = rx.recv() => match recv {\n73\t                    Ok(env) => {\n74\t                        if env.event.root_task_id() != Some(root_task_id) {\n75\t                            continue;\n76\t                        }\n77\t                        let close = matches!(env.event, PlatformEvent::JobCompleted { .. });\n78\t                        yield Ok(to_sse(&env));\n79\t                        if close {\n80\t                            break;\n81\t                        }\n82\t                    }\n83\t                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,\n84\t                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,\n85\t                }\n86\t            }\n87\t        }\n88\t    };\n89\t    Ok(Sse::new(stream).keep_alive(KeepAlive::new().interval(Duration::from_secs(30))))\n90\t}\n91\t\n92\t#[derive(Debug, Deserialize)]\n93\tstruct JobLogStreamQuery {\n94\t    category: Option<common::enums::LogCategory>,\n95\t    task_id: Option<Uuid>,\n96\t}\n97\t\n98\tasync fn job_logs_stream_handler(\n99\t    auth: AuthContext,\n100\t    headers: HeaderMap,\n101\t    State(state): State<AppState>,\n102\t    Path(root_task_id): Path<Uuid>,\n103\t    Query(q): Query<JobLogStreamQuery>,\n104\t) -> Result<Sse<impl Stream<Item = Result<SseEvent, Infallible>>>, AppError> {\n105\t    let job = crate::db::jobs::get_job(&state.db, root_task_id)\n106\t        .await\n107\t        .map_err(|e| AppError::Internal {\n108\t            message: e.to_string(),\n109\t        })?\n110\t        .ok_or_else(|| AppError::NotFound {\n111\t            resource: \"job\",\n112\t            id: root_task_id.to_string(),\n113\t        })?;\n114\t    require_viewer(&state.db, job.job.team_id, &auth).await?;\n115\t    let mut rx = state.event_bus.subscribe();\n116\t    let replay = state.event_bus.replay_since(parse_last_event_id(&headers));\n117\t    let stream = async_stream::stream! {\n118\t        for env in replay {\n119\t            if let PlatformEvent::LogEntry { root_task_id: rt, task_id, log_entry, .. } = &env.event {\n120\t                if *rt != root_task_id { continue; }\n121\t                if q.task_id.is_some() && q.task_id != Some(*task_id) { continue; }\n122\t                if q.category.is_some() && q.category != Some(log_entry.category) { continue; }\n123\t                yield Ok(to_sse(&env));\n124\t            }\n125\t        }\n126\t        let mut ticker = tokio::time::interval(Duration::from_secs(30));\n127\t        loop {\n128\t            tokio::select! {\n129\t                _ = ticker.tick() => yield Ok(SseEvent::default().comment(\"keepalive\")),\n130\t                recv = rx.recv() => match recv {\n131\t                    Ok(env) => {\n132\t                        if let PlatformEvent::LogEntry { root_task_id: rt, task_id, log_entry, .. } = &env.event {\n133\t                            if *rt != root_task_id { continue; }\n134\t                            if q.task_id.is_some() && q.task_id != Some(*task_id) { continue; }\n135\t                            if q.category.is_some() && q.category != Some(log_entry.category) { continue; }\n136\t                            yield Ok(to_sse(&env));\n137\t                        } else if matches!(env.event, PlatformEvent::JobCompleted { root_task_id: rt, .. } if rt == root_task_id) {\n138\t                            break;\n139\t                        }\n140\t                    }\n141\t                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,\n142\t                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,\n143\t                }\n144\t            }\n145\t        }\n146\t    };\n147\t    Ok(Sse::new(stream).keep_alive(KeepAlive::new().interval(Duration::from_secs(30))))\n148\t}\n149\t\n150\tasync fn team_events_handler(\n151\t    auth: AuthContext,\n152\t    headers: HeaderMap,\n153\t    State(state): State<AppState>,\n154\t    Path(team_id): Path<Uuid>,\n155\t) -> Result<Sse<impl Stream<Item = Result<SseEvent, Infallible>>>, AppError> {\n156\t    require_viewer(&state.db, team_id, &auth).await?;\n157\t    let mut rx = state.event_bus.subscribe();\n158\t    let replay = state.event_bus.replay_since(parse_last_event_id(&headers));\n159\t    let stream = async_stream::stream! {\n160\t        for env in replay.into_iter().filter(|e| e.event.team_id() == team_id) {\n161\t            yield Ok(to_sse(&env));\n162\t        }\n163\t        let mut ticker = tokio::time::interval(Duration::from_secs(30));\n164\t        loop {\n165\t            tokio::select! {\n166\t                _ = ticker.tick() => yield Ok(SseEvent::default().comment(\"keepalive\")),\n167\t                recv = rx.recv() => match recv {\n168\t                    Ok(env) => {\n169\t                        if env.event.team_id() == team_id {\n170\t                            yield Ok(to_sse(&env));\n171\t                        }\n172\t                    }\n173\t                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,\n174\t                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,\n175\t                }\n176\t            }\n177\t        }\n178\t    };\n179\t    Ok(Sse::new(stream).keep_alive(KeepAlive::new().interval(Duration::from_secs(30))))\n180\t}\n181\t\n182\tasync fn global_events_handler(\n183\t    auth: AuthContext,\n184\t    headers: HeaderMap,\n185\t    State(state): State<AppState>,\n186\t) -> Result<Sse<impl Stream<Item = Result<SseEvent, Infallible>>>, AppError> {\n187\t    let team_ids: Vec<Uuid> =\n188\t        sqlx::query_scalar(r#\"SELECT team_id FROM team_members WHERE entity_id = $1\"#)\n189\t            .bind(auth.entity_id)\n190\t            .fetch_all(&state.db)\n191\t            .await\n192\t            .map_err(|e| AppError::Internal {\n193\t                message: e.to_string(),\n194\t            })?;\n195\t    let allowed: HashSet<Uuid> = team_ids.into_iter().collect();\n196\t    let mut rx = state.event_bus.subscribe();\n197\t    let replay = state.event_bus.replay_since(parse_last_event_id(&headers));\n198\t    let stream = async_stream::stream! {\n199\t        for env in replay.into_iter().filter(|e| allowed.contains(&e.event.team_id())) {\n200\t            yield Ok(to_sse(&env));\n201\t        }\n202\t        let mut ticker = tokio::time::interval(Duration::from_secs(30));\n203\t        loop {\n204\t            tokio::select! {\n205\t                _ = ticker.tick() => yield Ok(SseEvent::default().comment(\"keepalive\")),\n206\t                recv = rx.recv() => match recv {\n207\t                    Ok(env) => {\n208\t                        if allowed.contains(&env.event.team_id()) {\n209\t                            yield Ok(to_sse(&env));\n210\t                        }\n211\t                    }\n212\t                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,\n213\t                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,\n214\t                }\n215\t            }\n216\t        }\n217\t    };\n218\t    Ok(Sse::new(stream).keep_alive(KeepAlive::new().interval(Duration::from_secs(30))))\n219\t}\n220\t\n221\tpub fn router() -> Router<AppState> {\n222\t    Router::new()\n223\t        .route(\"/events\", get(global_events_handler))\n224\t        .route(\"/jobs/:root_task_id/events\", get(job_events_handler))\n225\t        .route(\n226\t            \"/jobs/:root_task_id/logs/stream\",\n227\t            get(job_logs_stream_handler),\n228\t        )\n229\t        .route(\"/teams/:team_id/events\", get(team_events_handler))\n230\t}\n231\t"}]},"parent_tool_use_id":"toolu_01GNGo3hHjPuggAghcHEPyyi","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"701ce046-7e62-427b-8b88-38a4891b3c35","timestamp":"2026-03-31T13:05:32.500Z"}
