tx.instance_id {\n122\t        return Err(AppError::Unauthorized {\n123\t            message: \"instance mismatch\".to_string(),\n124\t        });\n125\t    }\n126\t    let task = task_db::update_task_status(&state.db, ctx.task_id, TaskStatus::InProgress)\n127\t        .await\n128\t        .map_err(|e| AppError::Internal {\n129\t            message: e.to_string(),\n130\t        })?;\n131\t    let inbox_name = inbox_name_for_task(&state.db, task.id).await?;\n132\t    state\n133\t        .heartbeat_tracker\n134\t        .update_heartbeat(ctx.instance_id, ctx.task_id);\n135\t    state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n136\t        team_id: task.team_id,\n137\t        root_task_id: task.root_task_id,\n138\t        task_id: task.id,\n139\t        inbox_name: inbox_name.clone(),\n140\t        status: task.status,\n141\t        started_at: task.started_at,\n142\t        completed_at: task.completed_at,\n143\t    });\n144\t    state.event_bus.publish(PlatformEvent::InstanceStarted {\n145\t        team_id: task.team_id,\n146\t        task_id: task.id,\n147\t        inbox_id: task.inbox_id,\n148\t        inbox_name,\n149\t    });\n150\t    Ok(StatusCode::OK)\n151\t}\n152\t\n153\tasync fn heartbeat_handler(\n154\t    ctx: InstanceContext,\n155\t    State(state): State<AppState>,\n156\t    Path(instance_id): Path<Uuid>,\n157\t    Json(payload): Json<HeartbeatRequest>,\n158\t) -> Result<StatusCode, AppError> {\n159\t    if instance_id != ctx.instance_id {\n160\t        return Err(AppError::Unauthorized {\n161\t            message: \"instance mismatch\".to_string(),\n162\t        });\n163\t    }\n164\t    state\n165\t        .heartbeat_tracker\n166\t        .update_heartbeat(instance_id, ctx.task_id);\n167\t    let task = task_db::get_task(&state.db, ctx.task_id)\n168\t        .await\n169\t        .map_err(|e| AppError::Internal {\n170\t            message: e.to_string(),\n171\t        })?\n172\t        .ok_or_else(|| AppError::NotFound {\n173\t            resource: \"task\",\n174\t            id: ctx.task_id.to_string(),\n175\t        })?;\n176\t    state.event_bus.publish(PlatformEvent::Heartbeat {\n177\t        team_id: task.team_id,\n178\t        root_task_id: task.root_task_id,\n179\t        task_id: task.id,\n180\t        timestamp: payload.timestamp.unwrap_or_else(Utc::now),\n181\t    });\n182\t    Ok(StatusCode::OK)\n183\t}\n184\t\n185\tasync fn logs_handler(\n186\t    ctx: InstanceContext,\n187\t    State(state): State<AppState>,\n188\t    Path(instance_id): Path<Uuid>,\n189\t    Json(entries): Json<Vec<log_db::LogEntryInput>>,\n190\t) -> Result<StatusCode, AppError> {\n191\t    if instance_id != ctx.instance_id {\n192\t        return Err(AppError::Unauthorized {\n193\t            message: \"instance mismatch\".to_string(),\n194\t        });\n195\t    }\n196\t    let task = task_db::get_task(&state.db, ctx.task_id)\n197\t        .await\n198\t        .map_err(|e| AppError::Internal {\n199\t            message: e.to_string(),\n200\t        })?\n201\t        .ok_or_else(|| AppError::NotFound {\n202\t            resource: \"task\",\n203\t            id: ctx.task_id.to_string(),\n204\t        })?;\n205\t    let inserted = log_db::insert_log_batch(&state.db, task.id, &entries)\n206\t        .await\n207\t        .map_err(|e| AppError::Internal {\n208\t            message: e.to_string(),\n209\t        })?;\n210\t    for row in inserted {\n211\t        state.event_bus.publish(PlatformEvent::LogEntry {\n212\t            team_id: task.team_id,\n213\t            root_task_id: task.root_task_id,\n214\t            task_id: task.id,\n215\t            log_entry: common::api::logs::LogEntryResponse {\n216\t                id: row.id,\n217\t                task_id: row.task_id,\n218\t                category: row.category,\n219\t                source: row.source,\n220\t                timestamp: row.timestamp,\n221\t                entry: row.entry,\n222\t            },\n223\t        });\n224\t    }\n225\t    Ok(StatusCode::OK)\n226\t}\n227\t\n228\tasync fn exited_handler(\n229\t    ctx: InstanceContext,\n230\t    State(state): State<AppState>,\n231\t    Path(instance_id): Path<Uuid>,\n232\t    Json(payload): Json<ExitedRequest>,\n233\t) -> Result<StatusCode, AppError> {\n234\t    if instance_id != ctx.instance_id {\n235\t        return Err(AppError::Unauthorized {\n236\t            message: \"instance mismatch\".to_string(),\n237\t        });\n238\t    }\n239\t    let _ = &payload.signal;\n240\t    let task = task_db::get_task(&state.db, ctx.task_id)\n241\t        .await\n242\t        .map_err(|e| AppError::Internal {\n243\t            message: e.to_string(),\n244\t        })?\n245\t        .ok_or_else(|| AppError::NotFound {\n246\t            resource: \"task\",\n247\t            id: ctx.task_id.to_string(),\n248\t        })?;\n249\t    let inbox_name = inbox_name_for_task(&state.db, task.id).await?;\n250\t    state.heartbeat_tracker.remove(instance_id);\n251\t    state.event_bus.publish(PlatformEvent::InstanceExited {\n252\t        team_id: task.team_id,\n253\t        task_id: task.id,\n254\t        inbox_id: task.inbox_id,\n255\t        inbox_name: inbox_name.clone(),\n256\t        exit_code: payload.exit_code,\n257\t    });\n258\t    if task.status == TaskStatus::InProgress {\n259\t        let retry_count = inbox_retry_count(&state.db, task.inbox_id).await?;\n260\t        let updated = task_db::fail_task_with_retry(&state.db, task.id, retry_count)\n261\t            .await\n262\t            .map_err(|e| AppError::Internal {\n263\t                message: e.to_string(),\n264\t            })?;\n265\t        state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n266\t            team_id: updated.team_id,\n267\t            root_task_id: updated.root_task_id,\n268\t            task_id: updated.id,\n269\t            inbox_name: inbox_name.clone(),\n270\t            status: updated.status,\n271\t            started_at: updated.started_at,\n272\t            completed_at: updated.completed_at,\n273\t        });\n274\t        if updated.status == TaskStatus::DeadLettered {\n275\t            state.event_bus.publish(PlatformEvent::DlqAddition {\n276\t                team_id: updated.team_id,\n277\t                root_task_id: updated.root_task_id,\n278\t                task_id: updated.id,\n279\t                inbox_name,\n280\t            });\n281\t        }\n282\t    }\n283\t    if let Some(job) = crate::db::jobs::get_job(&state.db, ctx.root_task_id)\n284\t        .await\n285\t        .map_err(|e| AppError::Internal {\n286\t            message: e.to_string(),\n287\t        })?\n288\t    {\n289\t        if matches!(\n290\t            job.job.status,\n291\t            JobStatus::Succeeded | JobStatus::Failed | JobStatus::Cancelled\n292\t        ) {\n293\t            state.event_bus.publish(PlatformEvent::JobCompleted {\n294\t                team_id: job.job.team_id,\n295\t                root_task_id: job.job.root_task_id,\n296\t                status: job.job.status,\n297\t                commit_sha: job.job.commit_sha,\n298\t                pr_url: job.job.pr_url,\n299\t                branch_name: job.job.branch_name,\n300\t            });\n301\t        }\n302\t    }\n303\t    Ok(StatusCode::OK)\n304\t}\n305\t\n306\tasync fn refresh_token_handler(\n307\t    ctx: InstanceContext,\n308\t    State(state): State<AppState>,\n309\t    Path(instance_id): Path<Uuid>,\n310\t) -> Result<Json<RefreshTokenResponse>, AppError> {\n311\t    if instance_id != ctx.instance_id {\n312\t        return Err(AppError::Unauthorized {\n313\t            message: \"instance mismatch\".to_string(),\n314\t        });\n315\t    }\n316\t    let tok = issue_instance_token(\n317\t        ctx.instance_id,\n318\t        ctx.task_id,\n319\t        ctx.root_task_id,\n320\t        state.config.heartbeat_interval_secs as i64 * 4,\n321\t        &state.config.jwt_keys,\n322\t    )\n323\t    .map_err(|e| AppError::Internal {\n324\t        message: e.to_string(),\n325\t    })?;\n326\t    Ok(Json(RefreshTokenResponse {\n327\t        instance_token: tok,\n328\t    }))\n329\t}\n330\t\n331\tasync fn complete_task_handler(\n332\t    claims: InstanceClaimsContext,\n333\t    State(state): State<AppState>,\n334\t    Path(task_id): Path<Uuid>,\n335\t    Json(payload): Json<CompleteTaskRequest>,\n336\t) -> Result<StatusCode, AppError> {\n337\t    if task_id != claims.task_id {\n338\t        return Err(AppError::Unauthorized {\n339\t            message: \"task mismatch\".to_string(),\n340\t        });\n341\t    }\n342\t    let updated = task_db::complete_task(&state.db, task_id, payload.result_summary.as_deref())\n343\t        .await\n344\t        .map_err(|e| AppError::Conflict {\n345\t            message: format!(\"invalid transition to completed: {e}\"),\n346\t        })?;\n347\t    let inbox_name = inbox_name_for_task(&state.db, updated.id).await?;\n348\t    state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n349\t        team_id: updated.team_id,\n350\t        root_task_id: updated.root_task_id,\n351\t        task_id: updated.id,\n352\t        inbox_name,\n353\t        status: updated.status,\n354\t        started_at: updated.started_at,\n355\t        completed_at: updated.completed_at,\n356\t    });\n357\t    Ok(StatusCode::OK)\n358\t}\n359\t\n360\tasync fn complete_and_create_next_handler(\n361\t    claims: InstanceClaimsContext,\n362\t    State(state): State<AppState>,\n363\t    Path(task_id): Path<Uuid>,\n364\t    Json(payload): Json<CompleteAndCreateNextRequest>,\n365\t) -> Result<StatusCode, AppError> {\n366\t    if task_id != claims.task_id {\n367\t        return Err(AppError::Unauthorized {\n368\t            message: \"task mismatch\".to_string(),\n369\t        });\n370\t    }\n371\t    if payload.target_inbox_id.is_none() && payload.target_inbox_name.is_none() {\n372\t        return Err(AppError::BadRequest {\n373\t            message: \"at least one of target_inbox_id or target_inbox_name is required\".into(),\n374\t        });\n375\t    }\n376\t    let (parent, child) = task_db::complete_task_and_create_next(\n377\t        &state.db,\n378\t        task_id,\n379\t        payload.target_inbox_id,\n380\t        payload.target_inbox_name.as_deref(),\n381\t        &payload.task_body,\n382\t        payload.result_summary.as_deref(),\n383\t    )\n384\t    .await\n385\t    .map_err(|e| match e {\n386\t        task_db::TaskDbError::Sqlx(sqlx::Error::RowNotFound) => AppError::BadRequest {\n387\t            message: \"target inbox not found in task team\".into(),\n388\t        },\n389\t        _ => AppError::Conflict {\n390\t            message: format!(\"invalid transition to completed+child: {e}\"),\n391\t        },\n392\t    })?;\n393\t    let parent_inbox_name = inbox_name_for_task(&state.db, parent.id).await?;\n394\t    let child_inbox_name = inbox_name_for_task(&state.db, child.id).await?;\n395\t    state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n396\t        team_id: parent.team_id,\n397\t        root_task_id: parent.root_task_id,\n398\t        task_id: parent.id,\n399\t        inbox_name: parent_inbox_name,\n400\t        status: parent.status,\n401\t        started_at: parent.started_at,\n402\t        completed_at: parent.completed_at,\n403\t    });\n404\t    state.event_bus.publish(PlatformEvent::TaskCreated {\n405\t        team_id: child.team_id,\n406\t        root_task_id: child.root_task_id,\n407\t        task_id: child.id,\n408\t        parent_task_id: Some(parent.id),\n409\t        inbox_id: child.inbox_id,\n410\t        inbox_name: child_inbox_name,\n411\t        body: child.body,\n412\t    });\n413\t    Ok(StatusCode::OK)\n414\t}\n415\t\n416\tasync fn fail_task_handler(\n417\t    claims: InstanceClaimsContext,\n418\t    State(state): State<AppState>,\n419\t    Path(task_id): Path<Uuid>,\n420\t    Json(payload): Json<FailTaskRequest>,\n421\t) -> Result<StatusCode, AppError> {\n422\t    if task_id != claims.task_id {\n423\t        return Err(AppError::Unauthorized {\n424\t            message: \"task mismatch\".to_string(),\n425\t        });\n426\t    }\n427\t    let task = task_db::get_task(&state.db, task_id)\n428\t        .await\n429\t        .map_err(|e| AppError::Internal {\n430\t            message: e.to_string(),\n431\t        })?\n432\t        .ok_or_else(|| AppError::NotFound {\n433\t            resource: \"task\",\n434\t            id: task_id.to_string(),\n435\t        })?;\n436\t    let retry_count = inbox_retry_count(&state.db, task.inbox_id).await?;\n437\t    let updated = task_db::fail_task_with_retry_reason(\n438\t        &state.db,\n439\t        task_id,\n440\t        retry_count,\n441\t        Some(&payload.reason),\n442\t    )\n443\t    .await\n444\t    .map_err(|e| AppError::Conflict {\n445\t        message: format!(\"invalid transition to failed: {e}\"),\n446\t    })?;\n447\t    let inbox_name = inbox_name_for_task(&state.db, updated.id).await?;\n448\t    state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n449\t        team_id: updated.team_id,\n450\t        root_task_id: updated.root_task_id,\n451\t        task_id: updated.id,\n452\t        inbox_name: inbox_name.clone(),\n453\t        status: updated.status,\n454\t        started_at: updated.started_at,\n455\t        completed_at: updated.completed_at,\n456\t    });\n457\t    if updated.status == TaskStatus::DeadLettered {\n458\t        state.event_bus.publish(PlatformEvent::DlqAddition {\n459\t            team_id: updated.team_id,\n460\t            root_task_id: updated.root_task_id,\n461\t            task_id: updated.id,\n462\t            inbox_name,\n463\t        });\n464\t    }\n465\t    Ok(StatusCode::OK)\n466\t}\n467\t\n468\tasync fn task_context_handler(\n469\t    claims: InstanceClaimsContext,\n470\t    State(state): State<AppState>,\n471\t    Path(task_id): Path<Uuid>,\n472\t    axum::extract::Query(query): axum::extract::Query<TaskContextQuery>,\n473\t) -> Result<Json<TaskContextResponse>, AppError> {\n474\t    if task_id != claims.task_id {\n475\t        return Err(AppError::Unauthorized {\n476\t            message: \"task mismatch\".to_string(),\n477\t        });\n478\t    }\n479\t    let include_bodies = query.include_bodies.unwrap_or(true);\n480\t    let chain = task_db::get_parent_chain(&state.db, task_id)\n481\t        .await\n482\t        .map_err(|e| AppError::Internal {\n483\t            message: e.to_string(),\n484\t        })?;\n485\t    let mut out = Vec::with_capacity(chain.len());\n486\t    for row in chain {\n487\t        let (inbox_name, agent_name): (String, String) = sqlx::query_as(\n488\t            r#\"\n489\t            SELECT i.name, s.name\n490\t            FROM inboxes i\n491\t            JOIN agent_snapshots s ON s.id = i.agent_snapshot_id\n492\t            WHERE i.id = $1\n493\t            \"#,\n494\t        )\n495\t        .bind(row.inbox_id)\n496\t        .fetch_one(&state.db)\n497\t        .await\n498\t        .map_err(|e| AppError::Internal {\n499\t            message: e.to_string(),\n500\t        })?;\n501\t        out.push(ContextTaskItem {\n502\t            task_id: row.id,\n503\t            inbox_name,\n504\t            agent_name,\n505\t            status: row.status,\n506\t            body: include_bodies.then_some(row.body),\n507\t            result_summary: row.result_summary,\n508\t            created_at: row.created_at,\n509\t        });\n510\t    }\n511\t    Ok(Json(TaskContextResponse { tasks: out }))\n512\t}\n513\t\n514\tasync fn job_logs_handler(\n515\t    claims: InstanceClaimsContext,\n516\t    State(state): State<AppState>,\n517\t    Path(root_task_id): Path<Uuid>,\n518\t    axum::extract::Query(query): axum::extract::Query<InternalLogsQuery>,\n519\t) -> Result<Json<InternalJobLogsResponse>, AppError> {\n520\t    if root_task_id != claims.root_task_id {\n521\t        return Err(AppError::Unauthorized {\n522\t            message: \"root task mismatch\".to_string(),\n523\t        });\n524\t    }\n525\t    let limit = query.limit.unwrap_or(100).clamp(1, 1000);\n526\t    let mut rows = crate::db::logs::query_logs_by_job(\n527\t        &state.db,\n528\t        root_task_id,\n529\t        query.category,\n530\t        query.since,\n531\t        query.until,\n532\t        None,\n533\t        limit,\n534\t    )\n535\t    .await\n536\t    .map_err(|e| AppError::Internal {\n537\t        message: e.to_string(),\n538\t    })?;\n539\t    if let Some(task_id) = query.task_id {\n540\t        rows.retain(|r| r.task_id == task_id);\n541\t    }\n542\t    let has_more = rows.len() > limit as usize;\n543\t    if has_more {\n544\t        rows.pop();\n545\t    }\n546\t    let entries = rows\n547\t        .into_iter()\n548\t        .map(|row| InternalLogEntry {\n549\t            task_id: row.task_id,\n550\t            category: row.category,\n551\t            source: row.source,\n552\t            timestamp: row.timestamp,\n553\t            entry: row.entry,\n554\t        })\n555\t        .collect();\n556\t    Ok(Json(InternalJobLogsResponse { entries, has_more }))\n557\t}\n558\t\n559\tasync fn inbox_name_for_task(pool: &sqlx::PgPool, task_id: Uuid) -> Result<String, AppError> {\n560\t    sqlx::query_scalar(\n561\t        r#\"SELECT i.name FROM tasks t JOIN inboxes i ON i.id = t.inbox_id WHERE t.id = $1\"#,\n562\t    )\n563\t    .bind(task_id)\n564\t    .fetch_one(pool)\n565\t    .await\n566\t    .map_err(|e| AppError::Internal {\n567\t        message: e.to_string(),\n568\t    })\n569\t}\n570\t\n571\tasync fn inbox_retry_count(pool: &sqlx::PgPool, inbox_id: Uuid) -> Result<i32, AppError> {\n572\t    sqlx::query_scalar(r#\"SELECT retry_count FROM inboxes WHERE id = $1\"#)\n573\t        .bind(inbox_id)\n574\t        .fetch_one(pool)\n575\t        .await\n576\t        .map_err(|e| AppError::Internal {\n577\t            message: e.to_string(),\n578\t        })\n579\t}\n580\t"}]},"parent_tool_use_id":null,"session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"179651fe-986b-4c03-9f0c-7b23ff39a4b9","timestamp":"2026-03-31T13:09:21.408Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/chizbro/Desktop/code/utils/agent_farm/crates/api-server/src/routes/internal.rs","content":"//! `/internal/instances/:id/*` — host wrapper callbacks (instance JWT).\n\nuse crate::db::{logs as log_db, tasks as task_db};\nuse crate::events::bus::PlatformEvent;\nuse crate::middleware::instance_auth::{InstanceClaimsContext, InstanceContext};\nuse crate::state::AppState;\nuse axum::extract::{Path, State};\nuse axum::http::StatusCode;\nuse axum::routing::{get, post};\nuse axum::Json;\nuse axum::Router;\nuse chrono::{DateTime, Utc};\nuse common::crypto::jwt::issue_instance_token;\nuse common::enums::LogCategory;\nuse common::enums::{JobStatus, TaskStatus};\nuse common::AppError;\nuse serde::{Deserialize, Serialize};\nuse uuid::Uuid;\n\npub fn router() -> Router<AppState> {\n    Router::new()\n        .route(\"/instances/:id/started\", post(started_handler))\n        .route(\"/instances/:id/heartbeat\", post(heartbeat_handler))\n        .route(\"/instances/:id/logs\", post(logs_handler))\n        .route(\"/instances/:id/exited\", post(exited_handler))\n        .route(\"/instances/:id/refresh-token\", post(refresh_token_handler))\n        .route(\"/tasks/:task_id/complete\", post(complete_task_handler))\n        .route(\n            \"/tasks/:task_id/complete-and-create-next\",\n            post(complete_and_create_next_handler),\n        )\n        .route(\"/tasks/:task_id/fail\", post(fail_task_handler))\n        .route(\"/tasks/:task_id/context\", get(task_context_handler))\n        .route(\"/jobs/:root_task_id/logs\", get(job_logs_handler))\n}\n\n#[derive(Debug, Deserialize)]\nstruct HeartbeatRequest {\n    timestamp: Option<DateTime<Utc>>,\n}\n\n#[derive(Debug, Deserialize)]\nstruct ExitedRequest {\n    exit_code: i32,\n    signal: Option<String>,\n}\n\n#[derive(Debug, Serialize)]\nstruct RefreshTokenResponse {\n    instance_token: String,\n}\n\n#[derive(Debug, Deserialize)]\nstruct CompleteTaskRequest {\n    result_summary: Option<String>,\n}\n\n#[derive(Debug, Deserialize)]\nstruct CompleteAndCreateNextRequest {\n    target_inbox_id: Option<Uuid>,\n    target_inbox_name: Option<String>,\n    task_body: String,\n    result_summary: Option<String>,\n}\n\n#[derive(Debug, Deserialize)]\nstruct FailTaskRequest {\n    reason: String,\n}\n\n#[derive(Debug, Deserialize)]\nstruct TaskContextQuery {\n    include_bodies: Option<bool>,\n}\n\n#[derive(Debug, Deserialize)]\nstruct InternalLogsQuery {\n    task_id: Option<Uuid>,\n    category: Option<LogCategory>,\n    since: Option<DateTime<Utc>>,\n    until: Option<DateTime<Utc>>,\n    limit: Option<i64>,\n}\n\n#[derive(Debug, Serialize)]\nstruct ContextTaskItem {\n    task_id: Uuid,\n    inbox_name: String,\n    agent_name: String,\n    status: TaskStatus,\n    body: Option<String>,\n    result_summary: Option<String>,\n    created_at: DateTime<Utc>,\n}\n\n#[derive(Debug, Serialize)]\nstruct TaskContextResponse {\n    tasks: Vec<ContextTaskItem>,\n}\n\n#[derive(Debug, Serialize)]\nstruct InternalLogEntry {\n    task_id: Uuid,\n    category: LogCategory,\n    source: common::enums::LogSource,\n    timestamp: DateTime<Utc>,\n    entry: serde_json::Value,\n}\n\n#[derive(Debug, Serialize)]\nstruct InternalJobLogsResponse {\n    entries: Vec<InternalLogEntry>,\n    has_more: bool,\n}\n\nasync fn started_handler(\n    ctx: InstanceContext,\n    State(state): State<AppState>,\n    Path(instance_id): Path<Uuid>,\n) -> Result<StatusCode, AppError> {\n    if instance_id != ctx.instance_id {\n        return Err(AppError::Unauthorized {\n            message: \"instance mismatch\".to_string(),\n        });\n    }\n    let task = task_db::update_task_status(&state.db, ctx.task_id, TaskStatus::InProgress)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?;\n    let inbox_name = inbox_name_for_task(&state.db, task.id).await?;\n    state\n        .heartbeat_tracker\n        .update_heartbeat(ctx.instance_id, ctx.task_id);\n    state.event_bus.publish(PlatformEvent::TaskStatusChanged {\n        team_id: task.team_id,\n        root_task_id: task.root_task_id,\n        task_id: task.id,\n        inbox_name: inbox_name.clone(),\n        status: task.status,\n        started_at: task.started_at,\n        completed_at: task.completed_at,\n    });\n    state.event_bus.publish(PlatformEvent::InstanceStarted {\n        team_id: task.team_id,\n        task_id: task.id,\n        inbox_id: task.inbox_id,\n        inbox_name,\n    });\n    Ok(StatusCode::OK)\n}\n\nasync fn heartbeat_handler(\n    ctx: InstanceContext,\n    State(state): State<AppState>,\n    Path(instance_id): Path<Uuid>,\n    Json(payload): Json<HeartbeatRequest>,\n) -> Result<StatusCode, AppError> {\n    if instance_id != ctx.instance_id {\n        return Err(AppError::Unauthorized {\n            message: \"instance mismatch\".to_string(),\n        });\n    }\n    state\n        .heartbeat_tracker\n        .update_heartbeat(instance_id, ctx.task_id);\n    let task = task_db::get_task(&state.db, ctx.task_id)\n        .await\n        .map_err(|e| AppError::Internal {\n            message: e.to_string(),\n        })?\n        .ok_or_else(|| AppError::NotFound {\n            resource: \"task\",\n            id: ctx.task_id.to_string(),\n        })?;\n    state.event_bus.publish(PlatformEvent::Heartbeat {\n        team_id: task.team_id,\n        root_task_id: task.root_task_id,\n        task_id: task.id,\n        timestamp: payload.timestamp.unwrap_or_else(Utc::now),\n    });\n    Ok(StatusCode::OK)\n}\n\nasync fn logs_handler(\n    ctx: InstanceContext,\n    State(state): State<AppState>,\n    Path(instance_id): Path<Uuid>,\n    Json(entries): Json<Vec<log_db::LogEntryInput>>,\n) -> Result<StatusCode, AppError> {\n    if instance_id != ctx.instance_id {\n        return Err(AppError::Unauthorized {\n            message: \"instance mismatch\".to_string(),\n        });\n    }\n    let task = task_db::get_task(&state.db, ctx