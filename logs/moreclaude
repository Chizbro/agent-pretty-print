             &request.sink_config.branch,\n                    &artifacts.commit_message,\n                    &artifacts.pr_description.unwrap_or_default(),\n                    &request.sink_config.credentials,\n                    None,\n                )\n                .await\n                .ok();\n                Ok(CommitPushResult {\n                    commit_sha: Some(commit_sha),\n                    pr_url,\n                    branch_name: Some(branch),\n                })\n            }\n        }\n    }\n\n    async fn cleanup_job_dir(&self, job_dir: &str) -> Result<(), SchedulerError> {\n        cleanup_job_dir_immediate(job_dir).await\n    }\n\n    fn active_instances(&self) -> u32 {\n        self.concurrency_manager.running_count()\n    }\n\n    fn status_label(&self) -> &'static str {\n        \"running\"\n    }\n}\n","numLines":217,"startLine":1,"totalLines":217}}}
