e(\n46\t            \"/identities/:provider\",\n47\t            post(post_link_identity).delete(delete_identity_route),\n48\t        )\n49\t}\n50\t\n51\t/// `GET /auth/cli/:device_code` (no `/api/v1` prefix); mounted from `router.rs`.\n52\tpub async fn cli_login_page(\n53\t    State(state): State<AppState>,\n54\t    Path(device_code): Path<String>,\n55\t) -> impl IntoResponse {\n56\t    let Some(sess) = state.device_sessions.get(&device_code) else {\n57\t        return (\n58\t            StatusCode::NOT_FOUND,\n59\t            Html(cli_error_page(\"Device login session not found.\")),\n60\t        )\n61\t            .into_response();\n62\t    };\n63\t    if sess.status != DeviceSessionStatus::Pending {\n64\t        return (\n65\t            StatusCode::GONE,\n66\t            Html(cli_error_page(\n67\t                \"This device login session is no longer valid.\",\n68\t            )),\n69\t        )\n70\t            .into_response();\n71\t    }\n72\t    if Instant::now() > sess.expires_at {\n73\t        return (\n74\t            StatusCode::GONE,\n75\t            Html(cli_error_page(\"This device login session has expired.\")),\n76\t        )\n77\t            .into_response();\n78\t    }\n79\t    let base = state.config.base_url.trim_end_matches('/');\n80\t    let api = format!(\"{base}/api/v1\");\n81\t    let dc_enc = urlencoding::encode(&device_code);\n82\t    let html = format!(\n83\t        r#\"<!DOCTYPE html>\n84\t<html lang=\"en\"><head><meta charset=\"utf-8\"/><title>Agent Farm — Sign in</title></head>\n85\t<body>\n86\t<h1>Sign in</h1>\n87\t<p>Choose a provider to complete CLI login.</p>\n88\t<form method=\"post\" action=\"{api}/auth/login/github?device_code={dc_enc}\">\n89\t  <button type=\"submit\">Sign in with GitHub</button>\n90\t</form>\n91\t<form method=\"post\" action=\"{api}/auth/login/gitlab?device_code={dc_enc}\">\n92\t  <button type=\"submit\">Sign in with GitLab</button>\n93\t</form>\n94\t</body></html>\"#,\n95\t    );\n96\t    (StatusCode::OK, Html(html)).into_response()\n97\t}\n98\t\n99\tfn cli_error_page(msg: &str) -> String {\n100\t    format!(\n101\t        r#\"<!DOCTYPE html><html><head><meta charset=\"utf-8\"/><title>Error</title></head>\n102\t<body><p>{}</p></body></html>\"#,\n103\t        html_escape(msg)\n104\t    )\n105\t}\n106\t\n107\tfn html_escape(s: &str) -> String {\n108\t    s.chars()\n109\t        .map(|c| match c {\n110\t            '<' => \"&lt;\".to_string(),\n111\t            '>' => \"&gt;\".to_string(),\n112\t            '&' => \"&amp;\".to_string(),\n113\t            '\"' => \"&quot;\".to_string(),\n114\t            _ => c.to_string(),\n115\t        })\n116\t        .collect()\n117\t}\n118\t\n119\tfn provider_path_segment(p: Provider) -> &'static str {\n120\t    match p {\n121\t        Provider::GitHub => \"github\",\n122\t        Provider::GitLab => \"gitlab\",\n123\t    }\n124\t}\n125\t\n126\tfn oauth_redirect_uri(base_url: &str, provider: Provider) -> String {\n127\t    format!(\n128\t        \"{}/api/v1/auth/callback/{}\",\n129\t        base_url.trim_end_matches('/'),\n130\t        provider_path_segment(provider)\n131\t    )\n132\t}\n133\t\n134\tfn parse_provider(s: &str) -> Result<Provider, AppError> {\n135\t    match s.to_lowercase().as_str() {\n136\t        \"github\" => Ok(Provider::GitHub),\n137\t        \"gitlab\" => Ok(Provider::GitLab),\n138\t        _ => Err(AppError::BadRequest {\n139\t            message: format!(\"unknown OAuth provider: {s}\"),\n140\t        }),\n141\t    }\n142\t}\n143\t\n144\t#[derive(Debug, Deserialize)]\n145\tpub struct LoginQuery {\n146\t    #[serde(default)]\n147\t    pub device_code: Option<String>,\n148\t    #[serde(default)]\n149\t    pub redirect_url: Option<String>,\n150\t}\n151\t\n152\tfn start_oauth(\n153\t    state: &AppState,\n154\t    provider: Provider,\n155\t    q: &LoginQuery,\n156\t    entity_id: Option<Uuid>,\n157\t) -> Result<AuthorizeUrlResponse, AppError> {\n158\t    let Some(cfg) = provider_config(&state.config, provider) else {\n159\t        return Err(AppError::BadRequest {\n160\t            message: format!(\"OAuth provider {provider:?} is not configured\"),\n161\t        });\n162\t    };\n163\t    let state_token = generate_opaque_token();\n164\t    let code_verifier = generate_opaque_token();\n165\t    let session = OAuthPendingSession {\n166\t        state: state_token.clone(),\n167\t        code_verifier: code_verifier.clone(),\n168\t        provider,\n169\t        device_code: q.device_code.clone(),\n170\t        redirect_url: q.redirect_url.clone(),\n171\t        entity_id,\n172\t        credential_user_id: None,\n173\t        credential_device_code: None,\n174\t        created_at: Instant::now(),\n175\t    };\n176\t    state.oauth_state.insert(session);\n177\t    let redirect_uri = oauth_redirect_uri(&state.config.base_url, provider);\n178\t    let authorize_url = build_authorize_url(&cfg, &state_token, &code_verifier, &redirect_uri);\n179\t    Ok(AuthorizeUrlResponse { authorize_url })\n180\t}\n181\t\n182\tfn auth_err_to_app(e: AuthError) -> AppError {\n183\t    AppError::BadRequest {\n184\t        message: e.to_string(),\n185\t    }\n186\t}\n187\t\n188\tasync fn post_login(\n189\t    State(state): State<AppState>,\n190\t    Path(provider_str): Path<String>,\n191\t    Query(q): Query<LoginQuery>,\n192\t) -> Result<Json<AuthorizeUrlResponse>, AppError> {\n193\t    let provider = parse_provider(&provider_str)?;\n194\t    Ok(Json(start_oauth(&state, provider, &q, None)?))\n195\t}\n196\t\n197\tasync fn post_link_identity(\n198\t    State(state): State<AppState>,\n199\t    Path(provider_str): Path<String>,\n200\t    Query(q): Query<LoginQuery>,"}]},"parent_tool_use_id":"toolu_01GNGo3hHjPuggAghcHEPyyi","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"cf669327-68fa-43be-a024-7ca460f0ad21","timestamp":"2026-03-31T13:05:31.981Z"}
