token) = create_service_principal_with_token(\n97\t        &state.db,\n98\t        &body.name,\n99\t        body.description.as_deref(),\n100\t        ctx.entity_id,\n101\t        cred_src,\n102\t    )\n103\t    .await\n104\t    .map_err(|e| {\n105\t        if let sqlx::Error::Database(dbe) = &e {\n106\t            if dbe.code().as_deref() == Some(\"23505\") {\n107\t                return AppError::Conflict {\n108\t                    message: \"service principal name already exists\".into(),\n109\t                };\n110\t            }\n111\t        }\n112\t        AppError::Internal {\n113\t            message: e.to_string(),\n114\t        }\n115\t    })?;\n116\t    Ok(Json(sp_to_response(row, Some(token))))\n117\t}\n118\t\n119\tasync fn get_sp(\n120\t    State(state): State<AppState>,\n121\t    Path(id): Path<Uuid>,\n122\t    ctx: AuthContext,\n123\t) -> Result<Json<ServicePrincipalResponse>, AppError> {\n124\t    require_user_admin(&state.db, &ctx).await?;\n125\t    let row = get_service_principal(&state.db, id)\n126\t        .await\n127\t        .map_err(|e| AppError::Internal {\n128\t            message: e.to_string(),\n129\t        })?\n130\t        .ok_or_else(|| AppError::NotFound {\n131\t            resource: \"service_principal\",\n132\t            id: id.to_string(),\n133\t        })?;\n134\t    Ok(Json(sp_to_response(row, None)))\n135\t}\n136\t\n137\tasync fn patch_sp(\n138\t    State(state): State<AppState>,\n139\t    Path(id): Path<Uuid>,\n140\t    ctx: AuthContext,\n141\t    Json(body): Json<UpdateServicePrincipalRequest>,\n142\t) -> Result<Json<ServicePrincipalResponse>, AppError> {\n143\t    require_user_admin(&state.db, &ctx).await?;\n144\t    let current = get_service_principal(&state.db, id)\n145\t        .await\n146\t        .map_err(|e| AppError::Internal {\n147\t            message: e.to_string(),\n148\t        })?\n149\t        .ok_or_else(|| AppError::NotFound {\n150\t            resource: \"service_principal\",\n151\t            id: id.to_string(),\n152\t        })?;\n153\t\n154\t    let name = body.name.as_ref().unwrap_or(&current.name);\n155\t    let description: Option<&str> = match &body.description {\n156\t        None => current.description.as_deref(),\n157\t        Some(s) => Some(s.as_str()),\n158\t    };\n159\t    let cred_src = match body.credential_source_user_id {\n160\t        None => current.credential_source_user_id,\n161\t        Some(new_src) if new_src == current.credential_source_user_id => new_src,\n162\t        Some(new_src) => {\n163\t            let role: Option<UserRole> =\n164\t                sqlx::query_scalar(r#\"SELECT role AS \"role: UserRole\" FROM users WHERE id = $1\"#)\n165\t                    .bind(new_src)\n166\t                    .fetch_optional(&state.db)\n167\t                    .await\n168\t                    .map_err(|e| AppError::Internal {\n169\t                        message: e.to_string(),\n170\t                    })?;\n171\t            let Some(role) = role else {\n172\t                return Err(AppError::ValidationFailed {\n173\t                    errors: vec![common::validation::ValidationError::new(\n174\t                        \"credential_source_user_id\",\n175\t                        \"user not found\",\n176\t                    )],\n177\t                });\n178\t            };\n179\t            if role != UserRole::Admin {\n180\t                return Err(AppError::ValidationFailed {\n181\t                    errors: vec![common::validation::ValidationError::new(\n182\t                        \"credential_source_user_id\",\n183\t                        \"credential source user must be an admin\",\n184\t                    )],\n185\t                });\n186\t            }\n187\t            new_src\n188\t        }\n189\t    };\n190\t\n191\t    let updated = update_service_principal_row(&state.db, id, name, description, cred_src)\n192\t        .await\n193\t        .map_err(|e| AppError::Internal {\n194\t            message: e.to_string(),\n195\t        })?\n196\t        .ok_or_else(|| AppError::NotFound {\n197\t            resource: \"service_principal\",\n198\t            id: id.to_string(),\n199\t        })?;\n200\t    Ok(Json(sp_to_response(updated, None)))\n201\t}\n202\t\n203\tasync fn delete_sp(\n204\t    State(state): State<AppState>,\n205\t    Path(id): Path<Uuid>,\n206\t    ctx: AuthContext,\n207\t) -> Result<StatusCode, AppError> {\n208\t    require_user_admin(&state.db, &ctx).await?;\n209\t    let n = service_principals::count_in_flight_tasks_for_submitter(&state.db, id)\n210\t        .await\n211\t        .map_err(|e| AppError::Internal {\n212\t            message: e.to_string(),\n213\t        })?;\n214\t    if n > 0 {\n215\t        return Err(AppError::Conflict {\n216\t            message: \"service principal has in-flight tasks\".into(),\n217\t        });\n218\t    }\n219\t    revoke_all_tokens(&state.db, id)\n220\t        .await\n221\t        .map_err(|e| AppError::Internal {\n222\t            message: e.to_string(),\n223\t        })?;\n224\t    remove_team_memberships_for_sp(&state.db, id)\n225\t        .await\n226\t        .map_err(|e| AppError::Internal {\n227\t            message: e.to_string(),\n228\t        })?;\n229\t    delete_service_principal_row(&state.db, id)\n230\t        .await\n231\t        .map_err(|e| AppError::Internal {\n232\t            message: e.to_string(),\n233\t        })?;\n234\t    Ok(StatusCode::NO_CONTENT)\n235\t}\n236\t\n237\tasync fn regenerate_sp_token(\n238\t    State(state): State<AppState>,\n239\t    Path(id): Path<Uuid>,\n240\t    ctx: AuthContext,\n241\t) -> Result<Json<RegenerateTokenResponse>, AppError> {\n242\t    require_user_admin(&state.db, &ctx).await?;\n243\t    let exists = get_service_principal(&state.db, id)\n244\t        .await\n245\t        .map_err(|e| AppError::Internal {\n246\t            message: e.to_string(),\n247\t        })?\n248\t        .is_some();\n249\t    if !exists {\n250\t        return Err(AppError::NotFound {\n251\t            resource: \"service_principal\",\n252\t            id: id.to_string(),\n253\t        });\n254\t    }\n255\t    revoke_all_tokens(&state.db, id)\n256\t        .await\n257\t        .map_err(|e| AppError::Internal {\n258\t            message: e.to_string(),\n259\t        })?;\n260\t    let token = generate_opaque_token();\n261\t    let th = hash_token(&token);\n262\t    insert_token(&state.db, id, &th)\n263\t        .await\n264\t        .map_err(|e| AppError::Internal {\n265\t            message: e.to_string(),\n266\t        })?;\n267\t    Ok(Json(RegenerateTokenResponse { token }))\n268\t}\n269\t\n270\t#[derive(Debug, Deserialize)]\n271\tstruct AdminUsersQuery {\n272\t    #[serde(default)]\n273\t    pub q: Option<String>,\n274\t    #[serde(default)]\n275\t    pub role: Option<UserRole>,\n276\t    #[serde(flatten)]\n277\t    pub page: PaginationParams,\n278\t}\n279\t\n280\tasync fn list_admin_users(\n281\t    State(state): State<AppState>,\n282\t    Query(q): Query<AdminUsersQuery>,\n283\t    ctx: AuthContext,\n284\t) -> Result<Json<AdminUserListResponse>, AppError> {\n285\t    require_user_admin(&state.db, &ctx).await?;\n286\t    let limit = q.page.limit();\n287\t    let (data, next_cursor) = admin_users::list_users(\n288\t        &state.db,\n289\t        q.q.as_deref(),\n290\t        q.role,\n291\t        q.page.cursor.as_deref(),\n292\t        limit,\n293\t    )\n294\t    .await?;\n295\t    Ok(Json(AdminUserListResponse { data, next_cursor }))\n296\t}\n297\t\n298\tasync fn patch_user_role(\n299\t    State(state): State<AppState>,\n300\t    Path(id): Path<Uuid>,\n301\t    ctx: AuthContext,\n302\t    Json(body): Json<UpdateUserRoleRequest>,\n303\t) -> Result<Json<common::api::admin::AdminUserResponse>, AppError> {\n304\t    require_user_admin(&state.db, &ctx).await?;\n305\t    if body.role == UserRole::Member {\n306\t        let n = admin_users::count_admins(&state.db)\n307\t            .await\n308\t            .map_err(|e| AppError::Internal {\n309\t                message: e.to_string(),\n310\t            })?;\n311\t        let target_is_admin: bool =\n312\t            sqlx::query_scalar(r#\"SELECT role = 'admin'::user_role FROM users WHERE id = $1\"#)\n313\t                .bind(id)\n314\t                .fetch_optional(&state.db)\n315\t                .await\n316\t                .map_err(|e| AppError::Internal {\n317\t                    message: e.to_string(),\n318\t                })?\n319\t                .unwrap_or(false);\n320\t        if target_is_admin && n <= 1 {\n321\t            return Err(AppError::Conflict {\n322\t                message: \"cannot demote the last admin\".into(),\n323\t            });\n324\t        }\n325\t    }\n326\t    let row = admin_users::update_user_role(&state.db, id, body.role)\n327\t        .await\n328\t        .map_err(|e| AppError::Internal {\n329\t            message: e.to_string(),\n330\t        })?\n331\t        .ok_or_else(|| AppError::NotFound {\n332\t            resource: \"user\",\n333\t            id: id.to_string(),\n334\t        })?;\n335\t    Ok(Json(row))\n336\t}\n337\t\n338\tasync fn get_deps(\n339\t    State(state): State<AppState>,\n340\t    Path(id): Path<Uuid>,\n341\t    ctx: AuthContext,\n342\t) -> Result<Json<UserDependenciesResponse>, AppError> {\n343\t    require_user_admin(&state.db, &ctx).await?;\n344\t    let deps = get_user_dependencies(&state.db, id)\n345\t        .await\n346\t        .map_err(|e| AppError::Internal {\n347\t            message: e.to_string(),\n348\t        })?;\n349\t    Ok(Json(deps))\n350\t}\n351\t\n352\tasync fn delete_user_route(\n353\t    State(state): State<AppState>,\n354\t    Path(id): Path<Uuid>,\n355\t    ctx: AuthContext,\n356\t) -> Result<StatusCode, AppError> {\n357\t    require_user_admin(&state.db, &ctx).await?;\n358\t    let deps = get_user_dependencies(&state.db, id)\n359\t        .await\n360\t        .map_err(|e| AppError::Internal {\n361\t            message: e.to_string(),\n362\t        })?;\n363\t    if !deps.can_delete {\n364\t        return Err(AppError::Conflict {\n365\t            message: \"user has blocking dependencies\".into(),\n366\t        });\n367\t    }\n368\t    let n = admin_users::count_admins(&state.db)\n369\t        .await\n370\t        .map_err(|e| AppError::Internal {\n371\t            message: e.to_string(),\n372\t        })?;\n373\t    let target_is_admin: bool =\n374\t        sqlx::query_scalar(r#\"SELECT role = 'admin'::user_role FROM users WHERE id = $1\"#)\n375\t            .bind(id)\n376\t            .fetch_optional(&state.db)\n377\t            .await\n378\t            .map_err(|e| AppError::Internal {\n379\t                message: e.to_string(),\n380\t            })?\n381\t            .unwrap_or(false);\n382\t    if target_is_admin && n <= 1 {\n383\t        return Err(AppError::Conflict {\n384\t            message: \"cannot delete the last admin\".into(),\n385\t        });\n386\t    }\n387\t    delete_user_records(&state.db, id)\n388\t        .await\n389\t        .map_err(|e| AppError::Internal {\n390\t            message: e.to_string(),\n391\t        })?;\n392\t    Ok(StatusCode::NO_CONTENT)\n393\t}\n394\t\n395\t#[derive(Debug, Deserialize)]\n396\tstruct ClientsQuery {\n397\t    #[serde(default)]\n398\t    pub status: Option<ClientStatus>,\n399\t}\n400\t\n401\tasync fn list_admin_clients(\n402\t    State(state): State<AppState>,\n403\t    Query(q): Query<ClientsQuery>,\n404\t    ctx: AuthContext,\n405\t) -> Result<Json<AdminClientListResponse>, AppError> {\n406\t    require_user_admin(&state.db, &ctx).await?;\n407\t    let data = client_db::list_clients(&state.db, q.status)\n408\t        .await\n409\t        .map_err(|e| AppError::Internal {\n410\t            message: e.to_string(),\n411\t        })?;\n412\t    Ok(Json(AdminClientListResponse { data }))\n413\t}\n414\t\n415\tasync fn approve_route(\n416\t    State(state): State<AppState>,\n417\t    Path(id): Path<String>,\n418\t    ctx: AuthContext,\n419\t) -> Result<Json<ClientResponse>, AppError> {\n420\t    require_user_admin(&state.db, &ctx).await?;\n421\t    let row = client_db::approve_client(&state.db, &id)\n422\t        .await\n423\t        .map_err(|e| AppError::Internal {\n424\t            message: e.to_string(),\n425\t        })?\n426\t        .ok_or_else(|| AppError::NotFound {\n427\t            resource: \"client\",\n428\t            id: id.clone(),\n429\t        })?;\n430\t    Ok(Json(row))\n431\t}\n432\t\n433\tasync fn deny_route(\n434\t    State(state): State<AppState>,\n435\t    Path(id): Path<String>,\n436\t    ctx: AuthContext,\n437\t) -> Result<StatusCode, AppError> {\n438\t    require_user_admin(&state.db, &ctx).await?;\n439\t    let ok = client_db::deny_client(&state.db, &id)\n440\t        .await\n441\t        .map_err(|e| AppError::Internal {\n442\t            message: e.to_string(),\n443\t        })?;\n444\t    if !ok {\n445\t        return Err(AppError::NotFound {\n446\t            resource: \"client\",\n447\t            id: id.clone(),\n448\t        });\n449\t    }\n450\t    Ok(StatusCode::NO_CONTENT)\n451\t}\n452\t\n453\tasync fn delete_client_route(\n454\t    State(state): State<AppState>,\n455\t    Path(id): Path<String>,\n456\t    ctx: AuthContext,\n457\t) -> Result<StatusCode, AppError> {\n458\t    require_user_admin(&state.db, &ctx).await?;\n459\t    client_db::delete_client(&state.db, &id).await?;\n460\t    Ok(StatusCode::NO_CONTENT)\n461\t}\n462\t"}]},"parent_tool_use_id":"toolu_01GNGo3hHjPuggAghcHEPyyi","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"64001e71-cee9-4938-8712-f8db65a6de42","timestamp":"2026-03-31T13:05:28.754Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011iu2yuijcZWNoQEuRsizzL","type":"tool_result","content":"1\t//! `/api/v1/credentials/*` plus `GET /credentials/cli/*` (mounted at app root).\n2\t\n3\tuse std::time::Instant;\n4\t\n5\tuse axum::extract::{Path, Query, State};\n6\tuse axum::http::StatusCode;\n7\tuse axum::response::{Html, IntoResponse, Redirect, Response};\n8\tuse axum::routing::{delete, get, post, put};\n9\tuse axum::{Json, Router};\n10\tuse common::api::auth::{AuthorizeUrlResponse, DeviceCodeResponse, DeviceTokenRequest};\n11\tuse common::api::credentials::{\n12\t    BranchListResponse, BranchSummary, CredentialListResponse, LlmApiKeyResponse, RepoListResponse,\n13\t    RepoSummary, SetLlmApiKeyRequest, SinkDevicePollSuccess,\n14\t};\n15\tuse common::crypto::encryption::{decrypt, encrypt};\n16\tuse common::crypto::tokens::generate_opaque_token;\n17\tuse common::enums::{EntityType, LlmProvider, Provider, SinkConnectionStatus, SinkProvider};\n18\tuse common::pagination::PaginationParams;\n19\tuse common::validation::ValidationError;\n20\tuse common::AppError;\n21\tuse serde::Deserialize;\n22\tuse uuid::Uuid;\n23\t\n24\tuse crate::auth::oauth_provider::{\n25\t    build_authorize_url, exchange_code, fetch_user_profile, sink_provider_config, AuthError,\n26\t};\n27\tuse crate::auth::oauth_state::OAuthPendingSession;\n28\tuse crate::auth::sink_device_sessions::{SinkDevicePollOutcome, SinkDeviceSessionStatus};\n29\tuse crate::db::credentials::{\n30\t    self, delete_llm_api_key, delete_sink_credential, encrypt_pair, get_sink_credential,\n31\t    upsert_llm_api_key, upsert_sink_credential,\n32\t};\n33\tuse crate::middleware::auth::{AuthContext, OptionalAuthContext};\n34\tuse crate::state::AppState;\n35\t\n36\tpub fn router() -> Router<AppState> {\n37\t    Router::new()\n38\t        .route(\"/\", get(list_credential_summary))\n39\t        .route(\"/sink/:provider/connect\", post(post_sink_connect))\n40\t        .route(\"/sink/:provider/callback\", get(sink_oauth_callback))\n41\t        .route(\"/sink/:provider\", delete(delete_sink))\n42\t        .route(\"/sink/:provider/device\", post(post_sink_device))\n43\t        .route(\"/sink/:provider/device/token\", post(post_sink_device_token))\n44\t        .route(\"/sink/:provider/repos\", get(get_repos))\n45\t        .route(\"/sink/:provider/repos/:repo/branches\", get(get_branches))\n46\t        .route(\"/llm/:provider\", put(put_llm_key).delete(delete_llm_route))\n47\t}\n48\t\n49\t/// `GET /credentials/cli/:device_code` at app root.\n50\tpub async fn sink_cli_page(\n51\t    State(state): State<AppState>,\n52\t    Path(device_code): Path<String>,\n53\t) -> impl IntoResponse {\n54\t    let Some(sess) = state.sink_device_sessions.get(&device_code) else {\n55\t        return (\n56\t            StatusCode::NOT_FOUND,\n57\t            Html(sink_cli_error(\"Device session not found.\")),\n58\t        )\n59\t            .into_response();\n60\t    };\n61\t    if sess.status != SinkDeviceSessionStatus::Pending {\n62\t        return (\n63\t            StatusCode::GONE,\n64\t            Html(sink_cli_error(\"This session is no longer valid.\")),\n65\t        )\n66\t            .into_response();\n67\t    };\n68\t    if Instant::now() > sess.expires_at {\n69\t        return (\n70\t            StatusCode::GONE,\n71\t            Html(sink_cli_error(\"This session has expired.\")),\n72\t        )\n73\t            .into_response();\n74\t    }\n75\t\n76\t    let base = state.config.base_url.trim_end_matches('/');\n77\t    let api = format!(\"{base}/api/v1\");\n78\t    let dc_enc = urlencoding::encode(&device_code);\n79\t    let html = format!(\n80\t        r#\"<!DOCTYPE html>\n81\t<html lang=\"en\"><head><meta charset=\"utf-8\"/><title>Connect sink — Agent Farm</title></head>\n82\t<body>\n83\t<h1>Connect repository host</h1>\n84\t<p>Authorize Agent Farm to access repositories on your behalf.</p>\n85\t<form method=\"post\" action=\"{api}/credentials/sink/github/connect?device_code={dc_enc}\">\n86\t  <button type=\"submit\">Connect GitHub</button>\n87\t</form>\n88\t<form method=\"post\" action=\"{api}/credentials/sink/gitlab/connect?device_code={dc_enc}\">\n89\t  <button type=\"submit\">Connect GitLab</button>\n90\t</form>\n91\t</body></html>\"#,\n92\t    );\n93\t    (StatusCode::OK, Html(html)).into_response()\n94\t}\n95\t\n96\tfn sink_cli_error(msg: &str) -> String {\n97\t    format!(\n98\t        r#\"<!DOCTYPE html><html><head><meta charset=\"utf-8\"/><title>Error</title></head>\n99\t<body><p>{}</p></body></html>\"#,\n100\t        html_escape(msg)\n101\t    )\n102\t}\n103\t\n104\tfn html_escape(s: &str) -> String {\n105\t    s.chars()\n106\t        .map(|c| match c {\n107\t            '<' => \"&lt;\".to_string(),\n108\t            '>' => \"&gt;\".to_string(),\n109\t            '&' => \"&amp;\".to_string(),\n110\t            '\"' => \"&quot;\".to_string(),\n111\t            _ => c.to_string(),\n112\t        })\n113\t        .collect()\n114\t}\n115\t\n116\tfn parse_provider(s: &str) -> Result<Provider, AppError> {\n117\t    match s.to_lowercase().as_str() {\n118\t        \"github\" => Ok(Provider::GitHub),\n119\t        \"gitlab\" => Ok(Provider::GitLab),\n120\t        _ => Err(AppError::BadRequest {\n121\t            message: format!(\"unknown OAuth provider: {s}\"),\n122\t        }),\n123\t    }\n124\t}\n125\t\n126\tfn parse_sink_provider_str(s: &str) -> Result<SinkProvider, AppError> {\n127\t    Ok(match parse_provider(s)? {\n128\t        Provider::GitHub => SinkProvider::GitHub,\n129\t        Provider::GitLab => SinkProvider::GitLab,\n130\t    })\n131\t}\n132\t\n133\tfn parse_llm_provider(s: &str) -> Result<LlmProvider, AppError> {\n134\t    match s.to_lowercase().as_str() {\n135\t        \"anthropic\" => Ok(LlmProvider::Anthropic),\n136\t        \"openai\" => Ok(LlmProvider::OpenAi),\n137\t        _ => Err(AppError::BadRequest {\n138\t            message: format!(\"unknown LLM provider: {s}\"),\n139\t        }),\n140\t    }\n141\t}\n142\t\n143\tfn sink_callback_segment(p: Provider) -> &'static str {\n144\t    match p {\n145\t        Provider::GitHub => \"github\",\n146\t        Provider::GitLab => \"gitlab\",\n147\t    }\n148\t}\n149\t\n150\tfn sink_redirect_uri(base_url: &str, provider: Provider) -> String {\n151\t    format!(\n152\t        \"{}/api/v1/credentials/sink/{}/callback\",\n153\t        base_url.trim_end_matches('/'),\n154\t        sink_callback_segment(provider)\n155\t    )\n156\t}\n157\t\n158\tfn auth_err_to_app(e: AuthError) -> AppError {\n159\t    AppError::BadRequest {\n160\t        message: e.to_string(),\n161\t    }\n162\t}\n163\t\n164\tasync fn require_credentials_user(ctx: &AuthContext) -> Result<Uuid, AppError> {\n165\t    if ctx.entity_type != EntityType::User {\n166\t        return Err(AppError::Forbidden {\n167\t            message: \"only users may manage credentials\".into(),\n168\t        });\n169\t    }\n170\t    Ok(ctx.entity_id)\n171\t}\n172\t\n173\t#[derive(Debug, Deserialize)]\n174\tpub struct SinkConnectQuery {\n175\t    #[serde(default)]\n176\t    pub device_code: Option<String>,\n177\t}\n178\t\n179\tasync fn resolve_connect_user_id(\n180\t    state: &AppState,\n181\t    q: &SinkConnectQuery,\n182\t    optional: OptionalAuthContext,\n183\t) -> Result<Uuid, AppError> {\n184\t    if let Some(dc) = &q.device_code {\n185\t        let sess = state\n186\t            .sink_device_sessions\n187\t            .get(dc)\n188\t            .ok_or_else(|| AppError::BadRequest {\n189\t                message: \"unknown or expired device_code\".into(),\n190\t            })?;\n191\t        if sess.status != SinkDeviceSessionStatus::Pending {\n192\t            return Err(AppError::BadRequest {\n193\t                message: \"device session is not pending\".into(),\n194\t            });\n195\t        }\n196\t        if Instant::now() > sess.expires_at {\n197\t            return Err(AppError::BadRequest {\n198\t                message: \"device session expired\".into(),\n199\t            });\n200\t        }\n201\t        Ok(sess.user_id)\n202\t    } else {\n203\t        let ctx = optional.0.ok_or_else(|| AppError::Unauthorized {\n204\t            message: \"Authorization required\".into(),\n205\t        })?;\n206\t        require_credentials_user(&ctx).await\n207\t    }\n208\t}\n209\t\n210\tasync fn post_sink_connect(\n211\t    State(state): State<AppState>,\n212\t    Path(provider_str): Path<String>,\n213\t    Query(q): Query<SinkConnectQuery>,\n214\t    optional: OptionalAuthContext,\n215\t) -> Result<Json<AuthorizeUrlResponse>, AppError> {\n216\t    let user_id = resolve_connect_user_id(&state, &q, optional).await?;\n217\t    let provider = parse_provider(&provider_str)?;\n218\t    let Some(cfg) = sink_provider_config(&state.config, provider) else {\n219\t        return Err(AppError::BadRequest {\n220\t            message: format!(\"OAuth provider {provider:?} is not configured\"),\n221\t        });\n222\t    };\n223\t    let state_token = generate_opaque_token();\n224\t    let code_verifier = generate_opaque_token();\n225\t    let session = OAuthPendingSession {\n226\t        state: state_token.clone(),\n227\t        code_verifier: code_verifier.clone(),\n228\t        provider,\n229\t        device_code: None,\n230\t        redirect_url: None,\n231\t        entity_id: None,\n232\t        credential_user_id: Some(user_id),\n233\t        credential_device_code: q.device_code.clone(),\n234\t        created_at: Instant::now(),\n235\t    };\n236\t    state.oauth_state.insert(session);\n237\t    let redirect_uri = sink_redirect_uri(&state.config.base_url, provider);\n238\t    let authorize_url = build_authorize_url(&cfg, &state_token, &code_verifier, &redirect_uri);\n239\t    Ok(Json(AuthorizeUrlResponse { authorize_url }))\n240\t}\n241\t\n242\t#[derive(Debug, Deserialize)]\n243\tpub(crate) struct SinkCallbackQuery {\n244\t    code: Option<String>,\n245\t    state: Option<String>,\n246\t    error: Option<String>,\n247\t    #[serde(default)]\n248\t    #[allow(dead_code)]\n249\t    error_description: Option<String>,\n250\t}\n251\t\n252\tpub(crate) async fn sink_oauth_callback(\n253\t    State(state): State<AppState>,\n254\t    Path(provider_str): Path<String>,\n255\t    Query(q): Query<SinkCallbackQuery>,\n256\t) -> Result<Response, AppError> {\n257\t    let url_provider = parse_provider(&provider_str)?;\n258\t    if let Some(err) = &q.error {\n259\t        let denied = err == \"access_denied\";\n260\t        if denied {\n261\t            if let Some(st) = &q.state {\n262\t                if let Some(session) = state.oauth_state.consume(st) {\n263\t                    if let Some(dc) = session.credential_device_code {\n264\t                        state.sink_device_sessions.deny(&dc);\n265\t                    }\n266\t                }\n267\t            }\n268\t            return Ok((\n269\t                StatusCode::FORBIDDEN,\n270\t                Html(sink_cli_error(\n271\t                    \"Access denied. You can close this window and return to the terminal.\",\n272\t                )),\n273\t            )\n274\t                .into_response());\n275\t        }\n276\t        return Err(AppError::BadRequest {\n277\t            message: format!(\"OAuth error: {err}\"),\n278\t        });\n279\t    }\n280\t\n281\t    let code = q.code.as_ref().ok_or_else(|| AppError::BadRequest {\n282\t        message: \"missing code\".into(),\n283\t    })?;\n284\t    let state_param = q.state.as_ref().ok_or_else(|| AppError::BadRequest {\n285\t        message: \"missing state\".into(),\n286\t    })?;\n287\t\n288\t    let session = state\n289\t        .oauth_state\n290\t        .consume(state_param)\n291\t        .ok_or_else(|| AppError::BadRequest {\n292\t            message: \"invalid or expired OAuth state\".into(),\n293\t        })?;\n294\t\n295\t    let Some(user_id) = session.credential_user_id else {\n296\t        return Err(AppError::BadRequest {\n297\t            message: \"OAuth state is not for sink credentials\".into(),\n298\t        });\n299\t    };\n300\t\n301\t    if session.provider != url_provider {\n302\t        return Err(AppError::BadRequest {\n303\t            message: \"OAuth provider mismatch\".into(),\n304\t        });\n305\t    }\n306\t\n307\t    let prov_cfg = sink_provider_config(&state.config, session.provider).ok_or_else(|| {\n308\t        AppError::BadRequest {\n309\t            message: \"OAuth provider not configured\".into(),\n310\t        }\n311\t    })?;\n312\t    let redirect_uri = sink_redirect_uri(&state.config.base_url, session.provider);\n313\t    let ptokens = exchange_code(\n314\t        &state.http_client,\n315\t        &prov_cfg,\n316\t        code,\n317\t        &session.code_verifier,\n318\t        &redirect_uri,\n319\t    )\n320\t    .await\n321\t    .map_err(auth_err_to_app)?;\n322\t    let profile = fetch_user_profile(\n323\t        &state.http_client,\n324\t        &prov_cfg,\n325\t        session.provider,\n326\t        &ptokens.access_token,\n327\t    )\n328\t    .await\n329\t    .map_err(auth_err_to_app)?;\n330\t\n331\t    let sink_prov = match session.provider {\n332\t        Provider::GitHub => SinkProvider::GitHub,\n333\t        Provider::GitLab => SinkProvider::GitLab,\n334\t    };\n335\t    let refresh_plain = ptokens.refresh_token.unwrap_or_default();\n336\t    let (enc_access, enc_refresh) = encrypt_pair(\n337\t        &ptokens.access_token,\n338\t        &refresh_plain,\n339\t        &state.config.encryption_keys,\n340\t    );\n341\t    upsert_sink_credential(\n342\t        &state.db,\n343\t        user_id,\n344\t        sink_prov,\n345\t        &enc_access,\n346\t        &enc_refresh,\n347\t        Some(profile.username.as_str()),\n348\t    )\n349\t    .await\n350\t    .map_err(|e| AppError::Internal {\n351\t        message: e.to_string(),\n352\t    })?;\n353\t\n354\t    if let Some(dc) = session.credential_device_code {\n355\t        let _ =\n356\t            state\n357\t                .sink_device_sessions\n358\t                .complete(&dc, session.provider, profile.username.clone());\n359\t    }\n360\t\n361\t    let target = format!(\n362\t        \"{}/credentials\",\n363\t        state.config.base_url.trim_end_matches('/')\n364\t    );\n365\t    Ok(Redirect::temporary(&target).into_response())\n366\t}\n367\t\n368\tasync fn list_credential_summary(\n369\t    State(state): State<AppState>,\n370\t    ctx: AuthContext,\n371\t) -> Result<Json<CredentialListResponse>, AppError> {\n372\t    let uid = require_credentials_user(&ctx).await?;\n373\t    let list = credentials::list_credentials(&state.db, uid)\n374\t        .await\n375\t        .map_err(|e| AppError::Internal {\n376\t            message: e.to_string(),\n377\t        })?;\n378\t    Ok(Json(list))\n379\t}\n380\t\n381\tasync fn delete_sink(\n382\t    State(state): State<AppState>,\n383\t    Path(provider_str): Path<String>,\n384\t    ctx: AuthContext,\n385\t) -> Result<StatusCode, AppError> {\n386\t    let uid = require_credentials_user(&ctx).await?;\n387\t    let sink_prov = parse_sink_provider_str(&provider_str)?;\n388\t    let row = get_sink_credential(&state.db, uid, sink_prov)\n389\t        .await\n390\t        .map_err(|e| AppError::Internal {\n391\t            message: e.to_string(),\n392\t        })?;\n393\t    let Some((enc_access, _enc_refresh)) = row else {\n394\t        return Ok(StatusCode::NO_CONTENT);\n395\t    };\n396\t    let access =\n397\t        decrypt(&enc_access, &state.config.encryption_keys).map_err(|e| AppError::Internal {\n398\t            message: format!(\"decrypt: {e}\"),\n399\t        })?;\n400\t    let access_s = String::from_utf8(access).map_err(|_| AppError::Internal {\n401\t        message: \"token is not UTF-8\".into(),\n402\t    })?;\n403\t    let provider = parse_provider(&provider_str)?;\n404\t    revoke_sink_at_provider(&state, provider, &access_s).await;\n405\t    delete_sink_credential(&state.db, uid, sink_prov)\n406\t        .await\n407\t        .map_err(|e| AppError::Internal {\n408\t            message: e.to_string(),\n409\t        })?;\n410\t    Ok(StatusCode::NO_CONTENT)\n411\t}\n412\t\n413\tasync fn revoke_sink_at_provider(state: &AppState, provider: Provider, access_token: &str) {\n414\t    match provider {\n415\t        Provider::GitHub => {\n416\t            let (Some(cid), Some(sec)) = (\n417\t                state.config.github_client_id.as_ref(),\n418\t                state.config.github_client_secret.as_ref(),\n419\t            ) else {\n420\t                tracing::warn!(\"GitHub OAuth not configured; skipping provider revoke\");\n421\t                return;\n422\t            };\n423\t            let res = state\n424\t                .http_client\n425\t                .post(\"https://github.com/login/oauth/revoke\")\n426\t                .form(&[\n427\t                    (\"client_id\", cid.as_str()),\n428\t                    (\"client_secret\", sec.as_str()),\n429\t                    (\"access_token\", access_token),\n430\t                ])\n431\t                .send()\n432\t                .await;\n433\t            if let Err(e) = res {\n434\t                tracing::warn!(error = %e, \"GitHub token revoke HTTP error\");\n435\t            } else if let Ok(r) = res {\n436\t                if !r.status().is_success() {\n437\t                    tracing::warn!(status = %r.status(), \"GitHub token revoke rejected\");\n438\t                }\n439\t            }\n440\t        }\n441\t        Provider::GitLab => {\n442\t            let (Some(cid), Some(sec)) = (\n443\t                state.config.gitlab_client_id.as_ref(),\n444\t                state.config.gitlab_client_secret.as_ref(),\n445\t            ) else {\n446\t                tracing::warn!(\"GitLab OAuth not configured; skipping provider revoke\");\n447\t                return;\n448\t            };\n449\t            let base = state.config.gitlab_api_base_url.trim_end_matches('/');\n450\t            let url = format!(\"{base}/oauth/revoke\");\n451\t        