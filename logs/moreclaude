llect();\n508\t    Ok(Json(PaginatedResponse {\n509\t        data,\n510\t        next_cursor: next,\n511\t    }))\n512\t}\n513\t\n514\tasync fn system_prompt_preview_handler(\n515\t    auth: AuthContext,\n516\t    State(state): State<AppState>,\n517\t    Path((team_id, inbox_id)): Path<(Uuid, Uuid)>,\n518\t) -> Result<Json<SystemPromptPreviewBody>, AppError> {\n519\t    require_viewer(&state.db, team_id, &auth).await?;\n520\t    let detail = teams::get_team(&state.db, team_id)\n521\t        .await\n522\t        .map_err(|e| AppError::Internal {\n523\t            message: e.to_string(),\n524\t        })?\n525\t        .ok_or_else(|| AppError::NotFound {\n526\t            resource: \"team\",\n527\t            id: team_id.to_string(),\n528\t        })?;\n529\t\n530\t    let joined = inboxes::fetch_inbox_joined(&state.db, team_id, inbox_id)\n531\t        .await\n532\t        .map_err(|e| AppError::Internal {\n533\t            message: e.to_string(),\n534\t        })?\n535\t        .ok_or_else(|| AppError::NotFound {\n536\t            resource: \"inbox\",\n537\t            id: inbox_id.to_string(),\n538\t        })?;\n539\t\n540\t    let inbox_rows = inboxes::list_inboxes(&state.db, team_id)\n541\t        .await\n542\t        .map_err(|e| AppError::Internal {\n543\t            message: e.to_string(),\n544\t        })?;\n545\t    let lines: Vec<SystemPromptInboxInfo> = inbox_rows\n546\t        .into_iter()\n547\t        .map(|r| SystemPromptInboxInfo {\n548\t            id: r.id,\n549\t            name: r.name,\n550\t            agent_name: r.snapshot_name,\n551\t            llm_host: r.snapshot_llm_host,\n552\t        })\n553\t        .collect();\n554\t\n555\t    let system_prompt = common::system_prompt::render_system_prompt_preview(\n556\t        &detail.team.name,\n557\t        team_id,\n558\t        &lines,\n559\t        joined.retry_count,\n560\t    );\n561\t\n562\t    Ok(Json(SystemPromptPreviewBody { system_prompt }))\n563\t}\n564\t\n565\tpub fn router() -> Router