EATE TABLE inboxes (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    team_id UUID NOT NULL REFERENCES teams(id) ON DELETE CASCADE,\n    name VARCHAR(255) NOT NULL,\n    agent_snapshot_id UUID NOT NULL REFERENCES agent_snapshots(id),\n    retry_count INTEGER NOT NULL DEFAULT 3,\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT inboxes_team_id_name_uniq UNIQUE (team_id, name)\n);\nCREATE INDEX idx_inboxes_team_id ON inboxes (team_id);\n```\n\n### Tasks\n```sql\nCREATE TABLE tasks (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    root_task_id UUID NOT NULL,\n    parent_task_id UUID REFERENCES tasks(id),\n    child_task_id UUID REFERENCES tasks(id),\n    inbox_id UUID NOT NULL REFERENCES inboxes(id),\n    team_id UUID NOT NULL REFERENCES teams(id),\n    status task_status NOT NULL DEFAULT 'queued'::task_status,\n    body TEXT NOT NULL,\n    retry_count INTEGER NOT NULL DEFAULT 0,\n    result_summary TEXT,\n    submitting_entity_type entity_type,\n    submitting_entity_id UUID,\n    client_id VARCHAR(255),\n    sink_provider sink_provider,\n    sink_repo_url TEXT,\n    sink_branch VARCHAR(255),\n    sink_push_mode push_mode,\n    started_at TIMESTAMPTZ,\n    completed_at TIMESTAMPTZ,\n    commit_sha VARCHAR(255),\n    branch_name VARCHAR(255),\n    pr_url TEXT,\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\nCREATE INDEX idx_tasks_root_task_id ON tasks (root_task_id);\nCREATE INDEX idx_tasks_inbox_id ON tasks (inbox_id);\nCREATE INDEX idx_tasks_team_id ON tasks (team_id);\nCREATE INDEX idx_tasks_status ON tasks (status);\nCREATE INDEX idx_tasks_team_id_status ON tasks (team_id, status);\nCREATE INDEX idx_tasks_created_at ON tasks (created_at);\n```\n\n### Jobs (derived status enum)\n```sql\nCREATE TYPE job_status AS ENUM ('running', 'succeeded', 'failed', 'cancelled');\n```\n\n### Logs\n```sql\nCREATE TABLE logs (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    tas