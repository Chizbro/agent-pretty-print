ULE: ENCRYPTION\n\n**File:** `/Users/chizbro/Desktop/code/utils/agent_farm/crates/common/src/crypto/encryption.rs`\n\n### Encryption Mechanism\n- **Algorithm:** AES-256-GCM (authenticated encryption with associated data)\n- **Key Size:** 256 bits (32 bytes)\n- **Nonce:** 12 bytes, randomly generated with OsRng for each encryption\n- **Output Format:** `nonce (12 bytes) || ciphertext || GCM tag (16 bytes)`\n\n### Key Configuration\nKeys are loaded from environment variables as base64-encoded 32-byte values:\n- `AGENT_FARM_ENCRYPTION_KEY` (required) - current encryption key\n- `AGENT_FARM_ENCRYPTION_KEY_PREVIOUS` (optional) - previous key for rotation support\n\nThe `EncryptionKeys` struct holds both current and previous keys, enabling seamless key rotation where old data encrypted with the previous key can still be decrypted.\n\n### Full Encryption Functions\n\n**Encrypt Function:**\n```rust\npub fn encrypt(plaintext: &[u8], key: &EncryptionKey) -> Vec<u8> {\n    let cipher_key = Key::<Aes256Gcm>::from_slice(key.as_bytes());\n    let cipher = Aes256Gcm::new(cipher_key);\n    let mut nonce = [0u8; NONCE_LEN];\n    OsRng.fill_bytes(&mut nonce);\n    let nonce = Nonce::from_slice(&nonce);\n    let mut out = Vec::with_capacity(NONCE_LEN + plaintext.len() + 16);\n    out.extend_from_slice(nonce.as_slice());\n    let ciphertext = cipher\n        .encrypt(nonce, plaintext)\n        .expect(\"encryption should succeed for valid sizes\");\n    out.extend_from_slice(&ciphertext);\n    out\n}\n```\n\n**Decrypt Function (with key rotation fallback):**\n```rust\npub fn decrypt(blob: &[u8], keys: &EncryptionKeys) -> Result<Vec<u8>, CryptoError> {\n    try_decrypt(blob, &keys.current).or_else(|_| {\n        if let Some(prev) = &keys.previous {\n            try_decrypt(blob, prev)\n        } else {\n            Err(CryptoError::DecryptionFailed)\n        }\n    })\n}\n\nfn try_decrypt(blob: &[u8], key: &EncryptionKey) -> Result<Vec<u8>, CryptoError> {\n    if blob.len() < NONCE_LEN + 16 {\n        return Err(CryptoError::InvalidCiphertext);\n    }\n    let cipher_key = Key::<Aes256Gcm>::from_slice(key.as_bytes());\n    let cipher = Aes256Gcm::new(cipher_key);\n    let nonce = Nonce::from_slice(&blob[..NONCE_LEN]);\n    let sealed = &blob[NONCE_LEN..];\n    cipher\n        .decrypt(nonce, sealed)\n        .map_err(|_| CryptoError::DecryptionFailed)\n}\n```\n\n### Error Handling\n```rust\n#[derive(Debug, Error, PartialEq, Eq)]\npub enum CryptoError {\n    #[error(\"decryption failed\")]\n    DecryptionFailed,\n    #[error(\"invalid encryption key\")]\n    InvalidKey,\n    #[error(\"invalid ciphertext\")]\n    InvalidCiphertext,\n}\n```\n\n---\n\n## 2. JWT TOKEN MODULE\n\n**File:** `/Users/chizbro/Desktop/code/utils/agent_farm/crates/common/src/crypto/jwt.rs`\n\n### Signing Algorithm & Keys\n- **Algorithm:** RS256 (RSA with SHA-256)\n- **Key Management:** RSA 2048-bit keys loaded from environment as PEM format\n- **Environment Variables:**\n  - `AGENT_FARM_JWT_PRIVATE_KEY` (required) - RSA private key for signing\n  - `AGENT_FARM_JWT_PUBLIC_KEY` (required) - RSA public key for verification\n  - `AGENT_FARM_JWT_PUBLIC_KEY_PREVIOUS` (optional) - previous public key for rotation\n\n### JWT Claims Structures\n\n**Access Token Claims:**\n```rust\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\npub struct AccessTokenClaims {\n    pub entity_type: EntityType,  // User or ServicePrincipal\n    pub entity_id: Uuid,\n    pub iat: i64,                 // issued at (seconds since epoch)\n    pub exp: i64,                 // expiration (seconds since epoch)\n}\n```\n\n**Instance Token Claims:**\n```rust\n#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]\npub struct InstanceTokenClaims {\n    pub instance_id: Uuid,\n    pub task_id: Uuid,\n    pub root_task_id: Uuid,\n    pub iat: i64,\n    pub exp: i64,\n}\n```\n\n### Token Creation Functions\n\n**Access Token Creation (15-minute lifetime):**\n```rust\npub fn issue_access_token(\n    entity_type: EntityType,\n    entity_id: Uuid,\n    keys: &JwtKeys,\n) -> Result<String, JwtError> {\n    let now = Utc::now().timestamp();\n    let claims = AccessTokenClaims {\n        entity_type,\n        entity_id,\n        iat: now,\n        exp: now + 15 * 60,  // 15 minutes\n    };\n    sign_access_token(&claims, keys)\n}\n\npub fn sign_access_token(claims: &AccessTokenClaims, keys: &JwtKeys) -> Result<String, JwtError> {\n    encode(\n        &Header::new(Algorithm::RS256),\n        claims,\n        keys.current_private(),\n    )\n    .map_err(|_| JwtError::SigningFailed)\n}\n```\n\n**Instance Token Creation (configurable lifetime):**\n```rust\npub fn issue_instance_token(\n    instance_id: Uuid,\n    task_id: Uuid,\n    root_task_id: Uuid,\n    lifetime_secs: i64,\n    keys: &JwtKeys,\n) -> Result<String, JwtError> {\n    let now = Utc::now().timestamp();\n    let claims = InstanceTokenClaims {\n        instance_id,\n        task_id,\n        root_task_id,\n        iat: now,\n        exp: now + lifetime_secs,\n    };\n    sign_instance_token(&claims, keys)\n}\n\npub fn sign_instance_token(\n    claims: &InstanceTokenClaims,\n    keys: &JwtKeys,\n) -> Result<String, JwtError> {\n    encode(\n        &Header::new(Algorithm::RS256),\n        claims,\n        keys.current_private(),\n    )\n    .map_err(|_| JwtError::SigningFailed)\n}\n```\n\n### Token Verification (with key rotation)\n```rust\npub fn verify_access_token(token: &str, keys: &JwtKeys) -> Result<AccessTokenClaims, JwtError> {\n    verify_with_fallback(token, keys.current_public(), keys.previous_public())\n}\n\npub fn verify_instance_token(token: &str, keys: &JwtKeys) -> Result<InstanceTokenClaims, JwtError> {\n    verify_with_fallback(token, keys.current_public(), keys.previous_public())\n}\n\nfn verify_with_fallback<T: serde::de::DeserializeOwned>(\n    token: &str,\n    current: &DecodingKey,\n    previous: Option<&DecodingKey>,\n) -> Result<T, JwtError> {\n    let v = validation();  // validates exp, uses RS256\n    match decode::<T>(token, current, &v) {\n        Ok(data) => Ok(data.claims),\n        Err(e) => {\n            use jsonwebtoken::errors::ErrorKind;\n            let kind = e.kind();\n            if matches!(kind, ErrorKind::ExpiredSignature) {\n                return Err(JwtError::Expired);\n            }\n            if let Some(prev) = previous {\n                match decode::<T>(token, prev, &v) {\n                    Ok(data) => Ok(data.claims),\n                    Err(e2) => {\n                        if matches!(e2.kind(), ErrorKind::ExpiredSignature) {\n                            Err(JwtError::Expired)\n                        } else {\n                            Err(JwtError::VerificationFailed)\n                        }\n                    }\n                }\n            } else {\n                Err(JwtError::VerificationFailed)\n            }\n        }\n    }\n}\n\nfn validation() -> Validation {\n    let mut v = Validation::new(Algorithm::RS256);\n    v.validate_exp = true;\n    v\n}\n```\n\n---\n\n## 3. OPAQUE TOKENS MODULE\n\n**File:** `/Users/chizbro/Desktop/code/utils/agent_farm/crates/common/src/crypto/tokens.rs`\n\n### Token Generation\n```rust\npub fn generate_opaque_token() -> String {\n    let mut buf = [0u8; 32];\n    rand::thread_rng().fill_bytes(&mut buf);\n    URL_SAFE_NO_PAD.encode(buf)  // base64url without padding\n}\n```\n\n### Token Hashing (for database storage)\n```rust\npub fn hash_token(token: &str) -> String {\n    let digest = Sha256::digest(token.as_bytes());\n    hex_lower(&digest)  // lowercase hex string\n}\n\npub fn generate_shared_secret() -> String {\n    generate_opaque_token()\n}\n```\n\nUsed for:\n- Refresh tokens (stored as SHA-256 hashes in DB)\n- Service principal tokens (stored as SHA-256 hashes in DB)\n- OAuth state/device codes\n\n---\n\n## 4. AUTH MIDDLEWARE\n\n**File:** `/Users/chizbro/Desktop/code/utils/agent_farm/crates/api-server/src/middleware/auth.rs`\n\n### AuthContext Extractor\n```rust\n#[derive(Clone, Debug)]\npub struct AuthContext {\n    pub entity_type: EntityType,  // User or ServicePrincipal\n    pub entity_id: Uuid,\n}\n```\n\n### Token Validation Flow\nThe middleware validates tokens in this order:\n\n1. **JWT Validation:** Attempts to verify as RS256 JWT\n2. **Service Principal Token Fallback:** If JWT fails, looks up token hash in `service_principal_tokens` table\n3. **Authorization Error:** If both fail, returns `Unauthorized`\n\n```rust\nasync fn resolve_bearer(state: &AppState, token: &str) -> Result<AuthContext, AppError> {\n    if token.is_empty() {\n        return Err(AppError::Unauthorized {\n            message: \"empty bearer token\".into(),\n        });\n    }\n\n    // Step 1: Try JWT verification\n    match verify_access_token(token, &state.config.jwt_keys) {\n        Ok(claims) => {\n            tracing::Span::current().record(\"entity_id\", tracing::field::display(claims.entity_id));\n            Ok(AuthContext {\n                entity_type: claims.entity_type,\n                entity_id: claims.entity_id,\n            })\n        }\n        Err(_) => {\n            // Step 2: Try service principal token lookup\n            let hash = hex::encode(Sha256::digest(token.as_bytes()));\n            let row = sqlx::query(\n                r#\"\n                SELECT service_principal_id\n                FROM service_principal_tokens\n                WHERE token_hash = $1 AND revoked_at IS NULL\n                LIMIT 1\n                \"#,\n            )\n            .bind(&hash)\n            .fetch_optional(&state.db)\n            .await\n            .map_err(|e| AppError::Internal {\n                message: e.to_string(),\n            })?;\n\n            let Some(r) = row else {\n                return Err(AppError::Unauthorized {\n                    message: \"invalid or expired token\".into(),\n                });\n            };\n\n            let entity_id: Uuid =\n                r.try_get(\"service_principal_id\")\n                    .map_err(|e| AppError::Internal {\n                        message: e.to_string(),\n                    })?;\n\n            tracing::Span::current().record(\"entity_id\", tracing::field::display(entity_id));\n            Ok(AuthContext {\n                entity_type: EntityType::ServicePrincipal,\n                entity_id,\n            })\n        }\n    }\n}\n```\n\n### Axum Extractors\n```rust\n#[async_trait::async_trait]\nimpl FromRequestParts<AppState> for AuthContext {\n    type Rejection = AppError;\n    async fn from_request_parts(\n        parts: &mut Parts,\n        state: &AppState,\n    ) -> Result<Self, Self::Rejection> {\n        let header = parts\n            .headers\n            .get(axum::http::header::AUTHORIZATION)\n            .and_then(|h| h.to_str().ok())\n            .ok_or_else(|| AppError::Unauthorized {\n                message: \"missing Authorization header\".into(),\n            })?;\n\n        let token = header\n            .strip_prefix(\"Bearer \")\n            .ok_or_else(|| AppError::Unauthorized {\n                message: \"Authorization header must be Bearer token\".into(),\n            })?\n            .trim();\n\n        resolve_bearer(state, token).await\n    }\n}\n\n#[async_trait::async_trait]\nimpl FromRequestParts<AppState> for OptionalAuthContext {\n    // Same flow but returns Ok(OptionalAuthContext(None)) if no Authorization header\n}\n```\n\n---\n\n## 5. DATABASE SCHEMA - MIGRATION FILES\n\n**Primary Migration:** `/Users/chizbro/Desktop/code/utils/agent_farm/migrations/20260331010000_full_schema.sql`\n\n### Users Table\n```sql\nCREATE TABLE users (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    display_name VARCHAR(255) NOT NULL,\n    email VARCHAR(255),\n    role user_role NOT NULL DEFAULT 'member'::user_role,\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n```\n\n### User Identities (OAuth)\n```sql\nCREATE TABLE user_identities (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    user_id UUID NOT NULL REFERENCES users(id) ON DELETE CASCADE,\n    provider provider NOT NULL,  -- github, gitlab\n    provider_user_id VARCHAR(255) NOT NULL,\n    provider_username VARCHAR(255) NOT NULL,\n    provider_email VARCHAR(255),\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    CONSTRAINT user_identities_provider_provider_user_id_uniq UNIQUE (provider, provider_user_id)\n);\nCREATE INDEX idx_user_identities_user_id ON user_identities (user_id);\n```\n\n### Service Principals\n```sql\nCREATE TABLE service_principals (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    name VARCHAR(255) NOT NULL UNIQUE,\n    description TEXT,\n    created_by UUID NOT NULL REFERENCES users(id),\n    credential_source_user_id UUID NOT NULL REFERENCES users(id),\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n```\n\n### Service Principal Tokens (opaque, hashed)\n```sql\nCREATE TABLE service_principal_tokens (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    service_principal_id UUID NOT NULL REFERENCES service_principals(id) ON DELETE CASCADE,\n    token_hash VARCHAR(255) NOT NULL,  -- SHA-256 hex\n    revoked_at TIMESTAMPTZ,            -- NULL = active, set to revoke\n    created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\nCREATE INDEX idx_service_principal_tokens_token_hash ON service_principal_tokens (token_hash);\nCREATE INDEX idx_service_principal_tokens_service_principal_id ON service_principal_tokens (service_principal_id);\n```\n\n### Refresh Tokens (opaque, hashed)\n```sql\nCREATE TABLE refresh_tokens (\n    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\n    entity_type entity_type NOT NULL,  -- user or service_principal\n    entity_id UUID NOT NULL,\n    token_hash VARCHAR(255) NOT NULL UNIQUE,  -- SHA-256 hex\n    expires_at TIMESTAMPTZ NOT NULL,\n    revoked_at TIMESTAMPTZ,\n    created_at TIMESTAMPTZ NOT