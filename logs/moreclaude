ect to test database\");\n49\t\n50\t    run_migrations(&pool).await.expect(\"run migrations\");\n51\t\n52\t    (pool, database_url, container)\n53\t}\n54\t\n55\tfn sample_rsa_pems() -> (String, String) {\n56\t    use std::sync::OnceLock;\n57\t    static PEM_PAIR: OnceLock<(String, String)> = OnceLock::new();\n58\t    PEM_PAIR\n59\t        .get_or_init(|| {\n60\t            use rand::SeedableRng;\n61\t            use rsa::pkcs8::{EncodePrivateKey, EncodePublicKey, LineEnding};\n62\t            use rsa::{RsaPrivateKey, RsaPublicKey};\n63\t            let mut rng = rand::rngs::StdRng::seed_from_u64(42);\n64\t            let private_key = RsaPrivateKey::new(&mut rng, 2048).expect(\"keygen\");\n65\t            let public_key = RsaPublicKey::from(&private_key);\n66\t            let priv_pem = private_key\n67\t                .to_pkcs8_pem(LineEnding::LF)\n68\t                .expect(\"pem\")\n69\t                .to_string();\n70\t            let pub_pem = public_key.to_public_key_pem(LineEnding::LF).expect(\"pem\");\n71\t            (priv_pem, pub_pem)\n72\t        })\n73\t        .clone()\n74\t}\n75\t\n76\tfn sample_encryption_key_b64() -> String {\n77\t    use base64::Engine;\n78\t    base64::engine::general_purpose::STANDARD.encode([9u8; 32])\n79\t}\n80\t\n81\t/// Sets env for [`AppConfig::from_env`]. Call with `DATABASE_URL` already set to the test container.\n82\tpub fn load_test_app_config() -> AppConfig {\n83\t    let _g = env_lock();\n84\t    let (priv_pem, pub_pem) = sample_rsa_pems();\n85\t    std::env::set_var(\"AGENT_FARM_BASE_URL\", \"http://localhost:8080\");\n86\t    std::env::set_var(\"AGENT_FARM_ENCRYPTION_KEY\", sample_encryption_key_b64());\n87\t    std::env::set_var(\"AGENT_FARM_JWT_PRIVATE_KEY\", &priv_pem);\n88\t    std::env::set_var(\"AGENT_FARM_JWT_PUBLIC_KEY\", &pub_pem);\n89\t    std::env::set_var(\"AGENT_FARM_HOST_WRAPPER_BIN\", \"/bin/host-wrap\");\n90\t    std::env::set_var(\"AGENT_FARM_MCP_SERVER_BIN\", \"/bin/mcp\");\n91\t    std::env::set_