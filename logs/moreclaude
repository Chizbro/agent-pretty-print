o_string(),\n            })?;\n        Ok(Self {\n            child,\n            stdin,\n            stdout: BufReader::new(stdout),\n            next_id: 1,\n        })\n    }\n\n    pub async fn initialize(&mut self) -> Result<(), MockAgentError> {\n        let init_id = self.take_id();\n        let _ = self\n            .request(json!({\n                \"jsonrpc\":\"2.0\",\n                \"id\": init_id,\n                \"method\":\"initialize\",\n                \"params\": {}\n            }))\n            .await?;\n        self.send_only(json!({\n            \"jsonrpc\":\"2.0\",\n            \"method\":\"notifications/initialized\",\n            \"params\": {}\n        }))\n        .await?;\n        Ok(())\n    }\n\n    pub async fn call_tool(&mut self, name: &str, args: Value) -> Result<Value, MockAgentError> {\n        let request_id = self.take_id();\n        let response = self\n            .request(json!({\n                \"jsonrpc\":\"2.0\",\n                \"id\": request_id,\n                \"method\":\"tools/call\",\n                \"params\": {\n                    \"name\": name,\n                    \"arguments\": args\n                }\n            }))\n            .await?;\n        if let Some(err) = response.get(\"error\") {\n            return Err(MockAgentError::McpCallFailed {\n                tool: name.to_string(),\n                message: err.to_string(),\n            });\n        }\n        let result = response.get(\"result\").cloned().unwrap_or_else(|| json!({}));\n        if result\n            .get(\"isError\")\n            .and_then(|v| v.as_bool())\n            .unwrap_or(false)\n        {\n            return Err(MockAgentError::McpCallFailed {\n                tool: name.to_string(),\n                message: result.to_string(),\n            });\n        }\n        Ok(result)\n    }\n\n    pub async fn close(mut self) -> Result<(), MockAgentError> {\n        drop(self.stdin);\n        let _ = self.child.wait().await?;\n        Ok(())\n    }\n\n    fn take_id(&mut self) -> u64 {\n        let id = self.next_id;\n        self.next_id += 1;\n        id\n    }\n\n    async fn send_only(&mut self, payload: Value) -> Result<(), MockAgentError> {\n        let line = serde_json::to_string(&payload).map_err(|e| MockAgentError::IoError {\n            message: e.to_string(),\n        })?;\n        self.stdin.write_all(line.as_bytes()).await?;\n        self.stdin.write_all(b\"\\n\").await?;\n        self.stdin.flush().await?;\n        Ok(())\n    }\n\n    async fn request(&mut self, payload: Value) -> Result<Value, MockAgentError> {\n        self.send_only(payload).await?;\n        let mut line = String::new();\n        loop {\n            line.clear();\n            let bytes = self.stdout.read_line(&mut line).await?;\n            if bytes == 0 {\n                return Err(MockAgentError::McpCallFailed {\n                    tool: \"jsonrpc\".to_string(),\n                    message: \"MCP server closed stdout\".to_string(),\n                });\n            }\n            let trimmed = line.trim();\n            if trimmed.is_empty() {\n                continue;\n            }\n            return serde_json::from_str(trimmed).map_err(|e| MockAgentError::McpCallFailed {\n                tool: \"jsonrpc\".to_string(),\n                message: e.to_string(),\n            });\n        }\n    }\n}\n\npub fn read_mcp_config(job_dir: &str) -> Result<McpServerEntry, MockAgentError> {\n    let path = PathBuf::from(job_dir).join(\".mcp.json\");\n    if !path.exists() {\n        return Err(MockAgentError::McpConfigNotFound {\n            job_dir: job_dir.to_string(),\n        });\n    }\n    let raw = std::fs::read_to_string(&path)?;\n    let parsed: McpFileClaude =\n        serde_json::from_str(&raw).map_err(|e| MockAgentError::ConfigError {\n            message: format!(\"invalid .mcp.json: {e}\"),\n        })?;\n    parsed\n        .mcp_servers\n        .get(\"agent-farm\")\n        .cloned()\n        .ok_or_else(|| MockAgentError::ConfigError {\n            message: \"missing mcpServers.agent-farm\".to_string(),\n        })\n}\n\n#[cfg(test)]\nmod tests {\n    use super::*;\n\n    #[test]\n    fn parses_claude_mcp_config() {\n        let dir = tempfile::tempdir().unwrap();\n        let file = dir.path().join(\".mcp.json\");\n        std::fs::write(\n            &file,\n            r#\"{\n  \"mcpServers\": {\n    \"agent-farm\": {\n      \"command\": \"/bin/mock\",\n      \"args\": [\"a\", \"b\"],\n      \"env\": {\"X\":\"1\"}\n    }\n  }\n}\"#,\n        )\n        .unwrap();\n        let entry = read_mcp_config(dir.path().to_str().unwrap()).unwrap();\n        assert_eq!(entry.command, \"/bin/mock\");\n        assert_eq!(entry.args, vec![\"a\".to_string(), \"b\".to_string()]);\n        assert_eq!(entry.env.get(\"X\").map(String::as_str), Some(\"1\"));\n    }\n}\n","numLines":217,"startLine":1,"totalLines":217}}}
