tion: Option<String>,\n}\n\npub struct TeamDetailResponse {\n    #[serde(flatten)]\n    pub team: TeamResponse,\n    pub inboxes: Vec<InboxResponse>,\n    pub dead_letter_queue: DeadLetterQueueSummary,\n}\n\npub struct DeadLetterQueueSummary {\n    pub id: Uuid,\n    pub task_count: i64,\n}\n```\n\n**InboxResponse**:\n```rust\npub struct InboxResponse {\n    pub id: Uuid,\n    pub name: String,\n    pub agent_snapshot_id: Uuid,\n    pub agent_snapshot: Option<InboxListSnapshotSummary>,\n    pub retry_count: i32,\n    pub queued_task_count: Option<i64>,\n    pub created_at: Option<DateTime<Utc>>,\n}\n\npub struct CreateInboxRequest {\n    pub name: String,\n    pub agent_id: Uuid,\n    pub retry_count: i32,\n}\n\npub struct UpdateInboxRequest {\n    pub name: Option<String>,\n    pub agent_id: Option<Uuid>,\n    pub retry_count: Option<i32>,\n}\n\npub struct InboxListSnapshotSummary {\n    pub id: Uuid,\n    pub name: String,\n    pub llm_host: LlmHost,\n    pub orphaned: bool,\n    pub source_agent_id: Option<Uuid>,\n}\n\npub struct AgentSnapshotResponse {\n    pub id: Uuid,\n    pub source_agent_id: Option<Uuid>,\n    pub source_version_id: Option<Uuid>,\n    pub source_version_number: Option<i32>,\n    pub orphaned: bool,\n    pub name: String,\n    pub description: Option<String>,\n    pub llm_host: LlmHost,\n    pub agent_prompt: String,\n    pub snapshot_created_at: DateTime<Utc>,\n}\n```\n\n**Team Membership**:\n```rust\npub struct TeamMemberResponse {\n    pub entity_type: EntityType,\n    pub entity_id: Uuid,\n    pub display_name: String,\n    pub access_level: AccessLevel,\n}\n\npub struct AddTeamMemberRequest {\n    pub entity_type: EntityType,\n    pub access_level: AccessLevel,\n}\n```\n\n---\n\n### 4. AGENT REGISTRY TYPES (in `crates/common/src/api/agents.rs`)\n\n```rust\npub struct AgentResponse {\n    pub id: Uuid,\n    pub name: String,\n    pub description: Option<String>,\n    pub visibility: AgentVisibility,\n    pub llm_host: LlmHost,\n    pub c