         .bind(&hash)\n51\t            .fetch_optional(&state.db)\n52\t            .await\n53\t            .map_err(|e| AppError::Internal {\n54\t                message: e.to_string(),\n55\t            })?;\n56\t\n57\t            let Some(r) = row else {\n58\t                return Err(AppError::Unauthorized {\n59\t                    message: \"invalid or expired token\".into(),\n60\t                });\n61\t            };\n62\t\n63\t            let entity_id: Uuid =\n64\t                r.try_get(\"service_principal_id\")\n65\t                    .map_err(|e| AppError::Internal {\n66\t                        message: e.to_string(),\n67\t                    })?;\n68\t\n69\t            tracing::Span::current().record(\"entity_id\", tracing::field::display(entity_id));\n70\t            Ok(AuthContext {\n71\t                entity_type: EntityType::ServicePrincipal,\n72\t                entity_id,\n73\t            })\n74\t        }\n75\t    }\n76\t}\n77\t\n78\t#[async_trait::async_trait]\n79\timpl FromRequestParts<AppState> for AuthContext {\n80\t    type Rejection = AppError;\n81\t\n82\t    async fn from_request_parts(\n83\t        parts: &mut Parts,\n84\t        state: &AppState,\n85\t    ) -> Result<Self, Self::Rejection> {\n86\t        let header = parts\n87\t            .headers\n88\t            .get(axum::http::header::AUTHORIZATION)\n89\t            .and_then(|h| h.to_str().ok())\n90\t            .ok_or_else(|| AppError::Unauthorized {\n91\t                message: \"missing Authorization header\".into(),\n92\t            })?;\n93\t\n94\t        let token = header\n95\t            .strip_prefix(\"Bearer \")\n96\t            .ok_or_else(|| AppError::Unauthorized {\n97\t                message: \"Authorization header must be Bearer token\".into(),\n98\t            })?\n99\t            .trim();\n100\t\n101\t        resolve_bearer(state, token).await\n102\t    }\n103\t}\n104\t\n105\t#[async_trait::async_trait]\n106\timpl FromRequestParts<AppState> for OptionalAuthContext {\n107\t    type Rejection = AppError;\n108\t\n109\t    async fn from_request_parts(\n110\t        parts: &mut Parts,\n111\t        state: &AppState,\n112\t    ) -> Result<Self, Self::Rejection> {\n113\t        let Some(header) = parts\n114\t            .headers\n115\t            .get(axum::http::header::AUTHORIZATION)\n116\t            .and_then(|h| h.to_str().ok())\n117\t        else {\n118\t            return Ok(OptionalAuthContext(None));\n119\t        };\n120\t\n121\t        let token = match header.strip_prefix(\"Bearer \") {\n122\t            Some(t) => t.trim(),\n123\t            None => {\n124\t                return Err(AppError::Unauthorized {\n125\t                    message: \"Authorization header must be Bearer token\".into(),\n126\t                });\n127\t            }\n128\t        };\n129\t\n130\t        if token.is_empty() {\n131\t            return Err(AppError::Unauthorized {\n132\t                message: \"empty bearer token\".into(),\n133\t            });\n134\t        }\n135\t\n136\t        let ctx = resolve_bearer(state, token).await?;\n137\t        Ok(OptionalAuthContext(Some(ctx)))\n138\t    }\n139\t}\n140\t"}]},"parent_tool_use_id":"toolu_01KT8bJnvxAUTFsh7jnMAXxC","session_id":"281ffad8-1750-48bf-9df8-885c78e7fc19","uuid":"b2a4c9cc-e52c-4422-a440-560e910f66bb","timestamp":"2026-03-31T13:05:24.983Z"}
