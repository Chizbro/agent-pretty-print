               if env.event.team_id() == team_id {\n170\t                            yield Ok(to_sse(&env));\n171\t                        }\n172\t                    }\n173\t                    Err(tokio::sync::broadcast::error::RecvError::Lagged(_)) => continue,\n174\t                    Err(tokio::sync::broadcast::error::RecvError::Closed) => break,\n175\t                }\n176\t            }\n177\t        }\n178\t    };\n179\t    Ok(Sse::new(stream).keep_alive(KeepAlive::new().interval(Duration::from_secs(30))))\n180\t}\n181\t\n182\tasync fn global_events_handler(\n183\t    auth: AuthContext,\n184\t    headers: HeaderMap,\n185\t    State(state): State<AppState>,\n186\t) -> Result<Sse<impl Stream<Item = Result<SseEvent, Infallible>>>, AppError> {\n187\t    let team_ids: Vec<Uuid> =\n188\t        sqlx::query_scalar(r#\"SELECT team_id FROM team_members WHERE entity_id = $1\"#)\n189\t            .bind(auth.entity_id)\n190\t            .fetch_all(&state.db)\n191\t            .await\n192\t            .map_err(|e| AppError::Internal {\n193\t                message: e.to_string(),\n194\t            })?;\n195\t    let allowed: HashSet<Uuid> = team_ids.into_iter().collect();\n196\t    let mut rx = state.event_bus.subscribe();\n197\t    let replay = state.event_bus.replay_since(parse_last_event_id(&headers));\n198\t    let stream = async_stream::stream! {\n199\t        for env in replay.into_iter().filter(|e| allowed.contains(&e.event.team_id())) {\n200\t            yield Ok(to_sse(&env));\n201\t        }\n202\t        let mut ticker = tokio::time::interval(Duration::from_secs(30));\n203\t        loop {\n204\t            tokio::select! {\n205\t                _ = ticker.tick() => yield Ok(SseEvent::default().comment(\"keepalive\")),\n206\t                recv = rx.recv() => match recv {\n207\t                    Ok(env) => {\n208\t                        if allowed.contains(&env.event.team_id()) {\n209\t                            yield Ok(to_sse(&env));\n210\t            