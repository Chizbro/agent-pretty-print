{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019dG2r2TymsM7TRg3NbQFai","type":"tool_result","content":"1\t//! AES-256-GCM encryption for credential fields at rest.\n2\t\n3\tuse aes_gcm::aead::{Aead, KeyInit, OsRng};\n4\tuse aes_gcm::{Aes256Gcm, Key, Nonce};\n5\tuse base64::Engine;\n6\tuse rand::RngCore;\n7\tuse thiserror::Error;\n8\t\n9\tconst NONCE_LEN: usize = 12;\n10\t\n11\t/// 256-bit key for AES-256-GCM (application credential encryption).\n12\t#[derive(Clone)]\n13\tpub struct EncryptionKey([u8; 32]);\n14\t\n15\timpl EncryptionKey {\n16\t    fn from_bytes(bytes: [u8; 32]) -> Self {\n17\t        Self(bytes)\n18\t    }\n19\t\n20\t    /// Raw key bytes (32 octets).\n21\t    pub fn as_bytes(&self) -> &[u8; 32] {\n22\t        &self.0\n23\t    }\n24\t}\n25\t\n26\t/// Current encryption key plus optional previous key for rotation.\n27\t#[derive(Clone)]\n28\tpub struct EncryptionKeys {\n29\t    pub current: EncryptionKey,\n30\t    pub previous: Option<EncryptionKey>,\n31\t}\n32\t\n33\timpl EncryptionKeys {\n34\t    /// Reads `AGENT_FARM_ENCRYPTION_KEY` (required) and optional `AGENT_FARM_ENCRYPTION_KEY_PREVIOUS`.\n35\t    pub fn from_env() -> Result<Self, crate::config::ConfigError> {\n36\t        let current = parse_required_key(\"AGENT_FARM_ENCRYPTION_KEY\")?;\n37\t        let previous = parse_optional_key(\"AGENT_FARM_ENCRYPTION_KEY_PREVIOUS\")?;\n38\t        Ok(Self { current, previous })\n39\t    }\n40\t}\n41\t\n42\tfn parse_required_key(var: &'static str) -> Result<EncryptionKey, crate::config::ConfigError> {\n43\t    let raw =\n44\t        std::env::var(var).map_err(|_| crate::config::ConfigError::MissingVar(var.to_string()))?;\n45\t    if raw.trim().is_empty() {\n46\t        return Err(crate::config::ConfigError::MissingVar(var.to_string()));\n47\t    }\n48\t    decode_encryption_key(var, &raw)\n49\t}\n50\t\n51\tfn parse_optional_key(\n52\t    var: &'static str,\n53\t) -> Result<Option<EncryptionKey>, crate::config::ConfigError> {\n54\t    let Ok(raw) = std::env::var(var) else {\n55\t        return Ok(None);\n56\t    };\n57\t    if raw.trim().is_empty() {\n58\t        return Ok(None);\n59\t    }\n60\t    Ok(Some(decode_encryption_key(var, &raw)?))\n61\t}\n62\t\n63\tfn decode_encryption_key(\n64\t    var: &'static str,\n65\t    raw: &str,\n66\t) -> Result<EncryptionKey, crate::config::ConfigError> {\n67\t    let bytes = base64::engine::general_purpose::STANDARD\n68\t        .decode(raw.trim())\n69\t        .map_err(|e| crate::config::ConfigError::InvalidValue {\n70\t            var: var.to_string(),\n71\t            reason: format!(\"invalid base64: {e}\"),\n72\t        })?;\n73\t    if bytes.len() != 32 {\n74\t        return Err(crate::config::ConfigError::InvalidValue {\n75\t            var: var.to_string(),\n76\t            reason: format!(\"expected 32 bytes after base64 decode, got {}\", bytes.len()),\n77\t        });\n78\t    }\n79\t    let mut arr = [0u8; 32];\n80\t    arr.copy_from_slice(&bytes);\n81\t    Ok(EncryptionKey::from_bytes(arr))\n82\t}\n83\t\n84\t#[derive(Debug, Error, PartialEq, Eq)]\n85\tpub enum CryptoError {\n86\t    #[error(\"decryption failed\")]\n87\t    DecryptionFailed,\n88\t    #[error(\"invalid encryption key\")]\n89\t    InvalidKey,\n90\t    #[error(\"invalid ciphertext\")]\n91\t    InvalidCiphertext,\n92\t}\n93\t\n94\t/// Encrypt with AES-256-GCM. Output: `nonce (12) || ciphertext || tag (16)`.\n95\tpub fn encrypt(plaintext: &[u8], key: &EncryptionKey) -> Vec<u8> {\n96\t    let cipher_key = Key::<Aes256Gcm>::from_slice(key.as_bytes());\n97\t    let cipher = Aes256Gcm::new(cipher_key);\n98\t    let mut nonce = [0u8; NONCE_LEN];\n99\t    OsRng.fill_bytes(&mut nonce);\n100\t    let nonce = Nonce::from_slice(&nonce);\n101\t    let mut out = Vec::with_capacity(NONCE_LEN + plaintext.len() + 16);\n102\t    out.extend_from_slice(nonce.as_slice());\n103\t    let ciphertext = cipher\n104\t        .encrypt(nonce, plaintext)\n105\t        .expect(\"encryption should succeed for valid sizes\");\n106\t    out.extend_from_slice(&ciphertext);\n107\t    out\n108\t}\n109\t\n110\t/// Decrypt with current key, then previous key if configured.\n111\tpub fn decrypt(blob: &[u8], keys: &EncryptionKeys) -> Result<Vec<u8>, CryptoError> {\n112\t    try_decrypt(blob, &keys.current).or_else(|_| {\n113\t        if let Some(prev) = &keys.previous {\n114\t            try_decrypt(blob, prev)\n115\t        } else {\n116\t            Err(CryptoError::DecryptionFailed)\n117\t        }\n118\t    })\n119\t}\n120\t\n121\tfn try_decrypt(blob: &[u8], key: &EncryptionKey) -> Result<Vec<u8>, CryptoError> {\n122\t    if blob.len() < NONCE_LEN + 16 {\n123\t        return Err(CryptoError::InvalidCiphertext);\n124\t    }\n125\t    let cipher_key = Key::<Aes256Gcm>::from_slice(key.as_bytes());\n126\t    let cipher = Aes256Gcm::new(cipher_key);\n127\t    let nonce = Nonce::from_slice(&blob[..NONCE_LEN]);\n128\t    let sealed = &blob[NONCE_LEN..];\n129\t    cipher\n130\t        .decrypt(nonce, sealed)\n131\t        .map_err(|_| CryptoError::DecryptionFailed)\n132\t}\n133\t\n134\t#[cfg(test)]\n135\tmod tests {\n136\t    use super::*;\n137\t\n138\t    fn key_from_seed(seed: u8) -> EncryptionKey {\n139\t        EncryptionKey::from_bytes([seed; 32])\n140\t    }\n141\t\n142\t    #[test]\n143\t    fn encrypt_decrypt_round_trip() {\n144\t        let key = key_from_seed(7);\n145\t        let keys = EncryptionKeys {\n146\t            current: key.clone(),\n147\t            previous: None,\n148\t        };\n149\t        let pt = b\"hello credential\";\n150\t        let ct = encrypt(pt, &key);\n151\t        assert_eq!(decrypt(&ct, &keys).unwrap(), pt);\n152\t    }\n153\t\n154\t    #[test]\n155\t    fn decrypt_wrong_key_fails() {\n156\t        let a = key_from_seed(1);\n157\t        let b = key_from_seed(2);\n158\t        let keys_b = EncryptionKeys {\n159\t            current: b,\n160\t            previous: None,\n161\t        };\n162\t        let ct = encrypt(b\"secret\", &a);\n163\t        assert_eq!(\n164\t            decrypt(&ct, &keys_b).unwrap_err(),\n165\t            CryptoError::DecryptionFailed\n166\t        );\n167\t    }\n168\t\n169\t    #[test]\n170\t    fn decrypt_with_previous_after_rotation() {\n171\t        let old_k = key_from_seed(10);\n172\t        let new_k = key_from_seed(11);\n173\t        let ct = encrypt(b\"rotated\", &old_k);\n174\t        let keys = EncryptionKeys {\n175\t            current: new_k,\n176\t            previous: Some(old_k),\n177\t        };\n178\t        assert_eq!(decrypt(&ct, &keys).unwrap(), b\"rotated\");\n179\t    }\n180\t\n181\t    #[test]\n182\t    fn decrypt_neither_key_fails() {\n183\t        let ct = encrypt(b\"x\", &key_from_seed(20));\n184\t        let keys = EncryptionKeys {\n185\t            current: key_from_seed(30),\n186\t            previous: Some(key_from_seed(40)),\n187\t        };\n188\t        assert_eq!(\n189\t            decrypt(&ct, &keys).unwrap_err(),\n190\t            CryptoError::DecryptionFailed\n191\t        );\n192\t    }\n193\t\n194\t    #[test]\n195\t    fn nonce_uniqueness() {\n196\t        let key = key_from_seed(5);\n197\t        let ct1 = encrypt(b\"sametext\", &key);\n198\t        let ct2 = encrypt(b\"sametext\", &key);\n199\t        assert_ne!(ct1, ct2);\n200\t    }\n201\t\n202\t    #[test]\n203\t    fn empty_plaintext_round_trip() {\n204\t        let key = key_from_seed(9);\n205\t        let keys = EncryptionKeys {\n206\t            current: key.clone(),\n207\t            previous: None,\n208\t        };\n209\t        let ct = encrypt(b\"\", &key);\n210\t        assert_eq!(decrypt(&ct, &keys).unwrap(), b\"\");\n211\t    }\n212\t\n213\t    #[test]\n214\t    fn corrupted_ciphertext_fails() {\n215\t        let key = key_from_seed(3);\n216\t        let keys = EncryptionKeys {\n217\t            current: key.clone(),\n218\t            previous: None,\n219\t        };\n220\t        let mut ct = encrypt(b\"data\", &key);\n221\t        let last = ct.len() - 1;\n222\t      