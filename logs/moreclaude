str) -> Option<String> {\n178\t    std::env::var(var).ok().filter(|s| !s.trim().is_empty())\n179\t}\n180\t\n181\tfn parse_cors_origins() -> Result<Vec<String>, ConfigError> {\n182\t    match std::env::var(\"AGENT_FARM_CORS_ORIGINS\") {\n183\t        Ok(raw) if !raw.trim().is_empty() => Ok(raw\n184\t            .split(',')\n185\t            .map(|s| s.trim().to_owned())\n186\t            .filter(|s| !s.is_empty())\n187\t            .collect()),\n188\t        _ => Ok(Vec::new()),\n189\t    }\n190\t}\n191\t\n192\tfn parse_u16(var: &'static str, default: u16) -> Result<u16, ConfigError> {\n193\t    let raw = match std::env::var(var) {\n194\t        Ok(s) if !s.trim().is_empty() => s,\n195\t        _ => return Ok(default),\n196\t    };\n197\t    raw.trim().parse().map_err(|e| ConfigError::InvalidValue {\n198\t        var: var.to_string(),\n199\t        reason: format!(\"expected u16: {e}\"),\n200\t    })\n201\t}\n202\t\n203\tfn parse_u32(var: &'static str, default: u32) -> Result<u32, ConfigError> {\n204\t    let raw = match std::env::var(var) {\n205\t        Ok(s) if !s.trim().is_empty() => s,\n206\t        _ => return Ok(default),\n207\t    };\n208\t    raw.trim().parse().map_err(|e| ConfigError::InvalidValue {\n209\t        var: var.to_string(),\n210\t        reason: format!(\"expected u32: {e}\"),\n211\t    })\n212\t}\n213\t\n214\tfn parse_u64(var: &'static str, default: u64) -> Result<u64, ConfigError> {\n215\t    let raw = match std::env::var(var) {\n216\t        Ok(s) if !s.trim().is_empty() => s,\n217\t        _ => return Ok(default),\n218\t    };\n219\t    raw.trim().parse().map_err(|e| ConfigError::InvalidValue {\n220\t        var: var.to_string(),\n221\t        reason: format!(\"expected u64: {e}\"),\n222\t    })\n223\t}\n224\t\n225\tfn parse_string_with_default(var: &'static str, default: String) -> Result<String, ConfigError> {\n226\t    match std::env::var(var) {\n227\t        Ok(s) if !s.trim().is_empty() => Ok(s),\n228\t        _ => Ok(default),\n229\t   